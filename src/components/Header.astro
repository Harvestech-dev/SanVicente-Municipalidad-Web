---
import datosSitio from "../data/sitio.json";
import { SocialIcon } from "./SocialIcon";

const navItems = [
  { label: "Inicio", href: "/" },
  { label: "Gobierno", href: "/gobierno" },
  {
    label: "Trámites",
    href: "/tramites",
    submenu: [
      // { label: "Licencia de Conducir", href: "/Tramites/licencia" }, // Oculto por el momento
      {
        label: "Boletas y Pagos",
        href: "https://sanvicente.miportal.ar/",
        target: "_blank",
      },
    ],
  },
  {
    label: "Transparencia",
    href: "/Transparencia",
    submenu: [
      {
        label: "Normativa",
        href: "https://sanvicentegestion.com.ar/normativa",
        target: "_blank",
      },
      {
        label: "Licitaciones",
        href: "/Transparencia/licitaciones",
      },
    ],
  },
  { label: "Programas", href: "/programas" },
  {
    label: "Actualidad",
    href: "/actualidad",
    submenu: [
      { label: "Noticias", href: "/noticias" },
      { label: "Agenda", href: "/agenda" },
    ],
  },
  // { label: "Recolección", href: "/recolecciones" }, // Oculto por el momento
  { label: "Contacto", href: "/contacto" },
];

const {
  nombreCorto = datosSitio.txt_nombreCorto,
  contacto = {},
  listaRedes = [],
} = Astro.props;

const whatsappItem = listaRedes?.find((r: { icon_contacto?: string }) => r.icon_contacto === "FaWhatsapp");
const whatsappLink = whatsappItem?.link_destino
  ? (whatsappItem.link_destino.includes("wa.me") ? whatsappItem.link_destino : `https://wa.me/${whatsappItem.link_destino.replace(/\D/g, "")}`)
  : null;
---

