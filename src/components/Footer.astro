---
import sitioData from "../data/sitio.json";

const {
  nombre = sitioData.txt_nombre,
  nombreCorto = sitioData.txt_nombreCorto,
  footer = sitioData.footer,
} = Astro.props;

const tema = sitioData._estilo;
const añoActual = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <div class="col-brand">
        <a href="/" class="footer-logo-link" aria-label={nombre}>
          <img
            src="/bandera_svc_blanco_iz.png"
            alt={nombre}
            class="footer-logo-img"
            width="400"
            loading="lazy"
          />
        </a>
        <p class="footer-desc">
          Trabajando cada día para construir la ciudad que soñamos. Gestión
          transparente, innovación y compromiso con cada vecino.
        </p>
        <div id="cms-footer-redes-root" class="social-grid" aria-live="polite">
          <span class="footer-cms-placeholder">Cargando redes…</span>
        </div>
      </div>

      <div class="col-links">
        <h3 class="footer-title">Contactos</h3>
        <div id="cms-footer-contact-root" aria-live="polite">
          <ul class="contact-list">
            <li><span class="footer-cms-placeholder">Cargando…</span></li>
          </ul>
        </div>
      </div>

      <div class="col-action">
        <h3 class="footer-title">Atención al Vecino</h3>
        <p class="action-desc">
          ¿Tenés alguna consulta o reclamo? Utilizá nuestro sistema online.
        </p>
        <a href={footer.btn_reclamos.link_url} class="btn-reclamos-fancy" target="_blank" rel="noopener noreferrer">
          <span>{footer.btn_reclamos.txt_label}</span>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="bottom-content">
        <p>
          &copy; {añoActual}
          <strong>{nombreCorto}</strong>. {footer.txt_copyright}
        </p>
        <p class="dev-credit">
          Desarrollado por <a
            href="https://harvi.digital"
            target="_blank"
            rel="noopener noreferrer">Harvi Digital</a
          >
        </p>
      </div>
    </div>
  </div>
</footer>

<style
  define:vars={{
    primario: tema.primario,
    primarioHover: tema.primarioHover,
    secundario: tema.secundario,
    fondoFooter: "#0f172a",
  }}
>
  .footer-cms-placeholder {
    color: #64748b;
    font-size: 0.9rem;
  }
  :global(.footer-cms-muted) {
    color: #64748b;
    font-size: 0.9rem;
    margin: 0;
  }
  .footer {
    background-color: var(--fondoFooter);
    color: #f1f5f9;
    padding: 5rem 0 2rem;
    font-family: "Inter", system-ui, sans-serif;
  }

  /**
   * IMPORTANTE:
   * El contenido dentro de `#cms-footer-*` se renderiza con React (hidratación),
   * por lo que no hereda el scope CSS de Astro. Estos estilos van en :global
   * para conservar colores/hover originales del footer.
   */
  :global(#cms-footer-contact-root a),
  :global(#cms-footer-redes-root a) {
    color: inherit;
    text-decoration: none;
  }

  :global(#cms-footer-redes-root .social-icon) {
    width: 42px;
    height: 42px;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.05);
    color: #94a3b8;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
  :global(#cms-footer-redes-root .social-icon:hover) {
    background: var(--primario);
    color: white;
    border-color: transparent;
  }

  :global(#cms-footer-contact-root .contact-list) {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  :global(#cms-footer-contact-root .contact-list li) {
    display: flex;
    gap: 12px;
    margin-bottom: 1.25rem;
    color: #cbd5e1;
    font-size: 0.95rem;
    align-items: flex-start;
  }
  :global(#cms-footer-contact-root .contact-icon) {
    color: var(--primario);
    flex-shrink: 0;
    margin-top: 3px;
    display: flex;
    align-items: center;
  }
  :global(#cms-footer-contact-root .contact-link) {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  :global(#cms-footer-contact-root .contact-link:hover) {
    color: var(--primario);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .footer-top {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 4rem;
    padding-bottom: 4rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-logo-link {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    text-decoration: none;
    width: 100%;
  }
  .footer-logo-img {
    width: min(150px, 100%);
    height: auto;
    max-width: 270px;

    object-fit: contain;
    object-position: left center;
  }

  @media (max-width: 480px) {
    .footer-logo-img {
      width: min(240px, 100%);
      max-width: 240px;
    }
  }

  .footer-desc {
    color: #94a3b8;
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .social-grid {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .social-icon {
    width: 42px;
    height: 42px;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.05);
    color: #94a3b8;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .social-icon:hover {
    background: var(--primario);
    color: white;
    border-color: transparent;
  }

  .footer-title {
    color: white;
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 1.75rem;
    position: relative;
  }

  .footer-title::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -8px;
    width: 35px;
    height: 3px;
    background: var(--primario);
  }

  .contact-list {
    list-style: none;
    padding: 0;
  }

  .contact-list li {
    display: flex;
    gap: 12px;
    margin-bottom: 1.25rem;
    color: #cbd5e1;
    font-size: 0.95rem;
    align-items: flex-start;
  }

  .contact-list svg,
  .contact-icon {
    color: var(--primario);
    flex-shrink: 0;
    margin-top: 3px;
    display: flex;
    align-items: center;
  }

  .contact-link {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .contact-link:hover {
    color: var(--primario);
  }

  .action-desc {
    color: #94a3b8;
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }

  .btn-reclamos-fancy {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: var(--primario);
    color: white;
    padding: 0.85rem 2rem;
    border: 1px solid var(--primario);
    border-radius: 14px;
    text-decoration: none;
    font-weight: 700;
    transition: all 0.3s ease;
  }

  .btn-reclamos-fancy:hover {
    transform: scale(1.05);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
    color: #0f172a;
  }

  .footer-bottom {
    padding-top: 2rem;
  }

  .bottom-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    color: #64748b;
    font-size: 0.85rem;
    text-align: center;
  }

  @media (min-width: 768px) {
    .bottom-content {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }

  .bottom-content strong {
    color: var(--primario);
  }

  .dev-credit a {
    color: #cbd5e1;
    text-decoration: none;
    font-weight: 600;
    transition: color 0.2s ease;
  }

  .dev-credit a:hover {
    color: var(--primario);
  }
</style>
