---
import Layout from "../layouts/Layout.astro";
import GobiernoPageClient from "../components/cms/GobiernoPageClient";
import sitio from "../data/sitio.json";

const isDevelopment =
  String(import.meta.env.ENVIRONMENT ?? import.meta.env.ENVIROMENT ?? "").toLowerCase() ===
  "development";
const clientSlug =
  String(import.meta.env.CLIENT_SLUG ?? import.meta.env.PUBLIC_CLIENT_SLUG ?? "").trim();
---

<Layout title={`Gobierno | ${sitio.txt_nombreCorto}`}>
  <GobiernoPageClient client:load clientSlug={clientSlug} isDevelopment={isDevelopment} />
</Layout>
