# URL base API miwebcms (componentes CMS: hero_carousel, banner, etc.)
# Ejemplo: https://api.miwebcms.com/api/public/v1
# Endpoints: /client-config, /cms-components
# Todo el contenido que viene del CMS (inicio, gobierno, contacto, footer redes/contactos)
# se carga en el navegador vía GET /cms-components. La API debe permitir CORS para tu origen.
PUBLIC_API_URL=

# Solo en desarrollo: slug del cliente para ?clientSlug= en llamadas API
# Ejemplo: sanvicente (también puedes usar PUBLIC_CLIENT_SLUG si lo necesitas en cliente)
CLIENT_SLUG=

# development | production. En development se agrega ?clientSlug=CLIENT_SLUG a las llamadas.
# Con development, noticias y agenda se leen primero desde public/data/noticiasLocal.json y
# agendaLocal.json (mismo formato array que la API Vecino). Útil si CORS bloquea la API en local.
# astro.config inyecta este flag en el JS del cliente; en deploy de producción usar ENVIRONMENT=production.
ENVIRONMENT=development

# URL base API Vecino Digital (noticias y eventos)
# Ejemplo: https://api-sanvicente.vecino.digital
# Endpoints: /citizen/news, /citizen/events
PUBLIC_API_VECINO_URL=
