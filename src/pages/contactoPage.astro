---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import data from "./../data/contactoPage/contacto-page.json";

const { hero, bannerDigital, oficinas, telefonosUtiles } = data;
---

<Layout title={`${hero.titulo} | Municipalidad de San Vicente (Santa Fe)`}>
  <Header />
  <main class="contact-page">
    <section class="hero-contact">
      <div class="container">
        <div class="hero-icon">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="32"
            height="32"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path
              d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
            ></path></svg
          >
        </div>
        <h1>{hero.titulo}</h1>
        <p>{hero.descripcion}</p>
      </div>
    </section>

    <section class="vecino-digital-wrapper">
      <div class="container">
        <div class="digital-card">
          <div class="digital-content">
            <div class="digital-badge">Contactanos</div>
            <h3>{bannerDigital.titulo}</h3>
            <p>{bannerDigital.subtitulo}</p>
          </div>
          <a href={bannerDigital.url} target="_blank" class="btn-digital-new">
            <span>{bannerDigital.textoBoton}</span>
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
                points="12 5 19 12 12 19"></polyline></svg
            >
          </a>
        </div>
      </div>
    </section>

    <section class="section-offices">
      <div class="container">
        <h2 class="section-title">Nuestras Oficinas</h2>
        <div class="offices-grid">
          {
            oficinas.map((oficina) => (
              <div class="office-card">
                <div class="office-header">
                  <div class="office-icon">
                    <svg
                      width="20"
                      height="20"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <>
                        <rect x="2" y="10" width="20" height="12" rx="2" />
                        <path d="M12 22V10" />
                        <path d="M12 10V5a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v5" />
                        <path d="M22 10V5a2 2 0 0 1 2-2h-6a2 2 0 0 1-2 2v5" />
                      </>
                    </svg>
                  </div>
                  <h3>{oficina.nombre}</h3>
                </div>
                <ul class="office-details">
                  <li>
                    <svg
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <>
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                        <circle cx="12" cy="10" r="3" />
                      </>
                    </svg>
                    <span>{oficina.direccion}</span>
                  </li>
                  <li>
                    <svg
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                    </svg>
                    <a href={`tel:${oficina.telefono}`}>{oficina.telefono}</a>
                  </li>
                  <li>
                    <svg
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <>
                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                        <polyline points="22,6 12,13 2,6" />
                      </>
                    </svg>
                    <a href={`mailto:${oficina.email}`}>{oficina.email}</a>
                  </li>
                </ul>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section-form">
      <div class="container grid-two-cols">
        <div class="useful-phones">
          <h2 class="section-subtitle">Nuestros teléfonos</h2>
          <p class="section-desc">
            Líneas de atención directa en nuestras oficinas.
          </p>
          <div class="phones-list">
            {
              telefonosUtiles.map((tel) => (
                <a
                  href={`tel:${tel.numero.replace(/[^0-9+]/g, "")}`}
                  class="phone-item"
                >
                  <div class="phone-info">
                    <span class="service-name">{tel.servicio}</span>
                    <span class="service-number">{tel.numero}</span>
                  </div>
                  <div class="phone-circle">
                    <svg
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="3"
                    >
                      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                    </svg>
                  </div>
                </a>
              ))
            }
          </div>
        </div>

        <div class="contact-form-container">
          <h2>Envianos un mensaje</h2>
          <p class="form-intro">
            Completá el formulario y nos pondremos en contacto a la brevedad.
          </p>
          <form class="contact-form">
            <div class="form-row">
              <div class="form-group">
                <label for="nombre">Nombre completo</label>
                <input
                  type="text"
                  id="nombre"
                  placeholder="Juan Pérez"
                  required
                />
              </div>
              <div class="form-group">
                <label for="email">Email</label>
                <input
                  type="email"
                  id="email"
                  placeholder="juan@email.com"
                  required
                />
              </div>
            </div>
            <div class="form-group">
              <label for="telefono">Teléfono</label>
              <input type="text" id="telefono" placeholder="(0351) 123-4567" />
            </div>
            <div class="form-group">
              <label for="asunto">Asunto</label>
              <input
                type="text"
                id="asunto"
                placeholder="Motivo de tu consulta"
              />
            </div>
            <div class="form-group">
              <label for="mensaje">Mensaje</label>
              <textarea
                id="mensaje"
                rows="4"
                placeholder="Escribí tu mensaje aquí..."></textarea>
            </div>
            <button type="submit" class="btn-submit">Enviar mensaje</button>
          </form>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* --- CONFIGURACIÓN BASE --- */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* --- HERO --- */
  .hero-contact {
    background-color: var(--color-secundario);
    color: white;
    padding: 5rem 0 8rem 0; /* Padding inferior extra para el solape del banner */
    text-align: center;
  }
  .hero-icon {
    background: rgba(255, 255, 255, 0.15);
    width: 64px;
    height: 64px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
  }
  .hero-contact h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 900;
    margin-bottom: 1rem;
    letter-spacing: -1px;
  }
  .hero-contact p {
    font-size: 1.2rem;
    opacity: 0.9;
    max-width: 600px;
    margin: 0 auto;
  }

  /* --- BANNER VECINO DIGITAL --- */
  .vecino-digital-wrapper {
    margin-top: -4rem;
    position: relative;
    z-index: 10;
  }
  .digital-card {
    background: white;
    padding: 2.5rem;
    border-radius: 2rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
    border: 1px solid rgba(0, 0, 0, 0.05);
  }
  .digital-badge {
    background: var(--color-primario-claro, #e0f2fe);
    color: var(--color-primario);
    padding: 0.4rem 1rem;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 700;
    display: inline-block;
    margin-bottom: 1rem;
  }
  .digital-content h3 {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--color-texto);
    margin-bottom: 0.5rem;
  }
  .digital-content p {
    color: #64748b;
    font-size: 1.1rem;
  }

  .btn-digital-new {
    background: var(--color-primario);
    color: white;
    padding: 1rem 2rem;
    border-radius: 1rem;
    text-decoration: none;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 1rem;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .btn-digital-new:hover {
    transform: scale(1.05);
    filter: brightness(1.1);
  }

  /* --- OFICINAS --- */
  .section-offices {
    padding: 6rem 0;
  }
  .section-title {
    text-align: center;
    font-size: 2.5rem;
    font-weight: 900;
    margin-bottom: 4rem;
  }
  .offices-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .office-card {
    padding: 2.5rem;
    border-radius: 1.5rem;
    background: white;
    border: 3px solid rgba(0, 0, 0, 0.15);
    transition: all 0.3s ease;
  }
  .office-card:hover {
    transform: translateY(-5px);
    border-color: var(--color-primario);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
  }

  .office-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .office-icon {
    background: var(--color-primario-claro, #eff6ff);
    color: var(--color-primario);
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .office-header h3 {
    font-weight: 800;
    font-size: 1.25rem;
    color: var(--color-primario);
    margin: 0;
  }

  .office-details {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }
  .office-details li {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: #475569;
    font-size: 0.95rem;
  }
  .office-details li svg {
    color: var(--color-primario);
    flex-shrink: 0;
  }

  /* Enlaces de Oficinas */
  .office-details a {
    color: inherit;
    text-decoration: none;
    transition: all 0.2s ease;
    border-bottom: 1px solid transparent;
  }
  .office-details a:hover {
    color: var(--color-primario);
    border-bottom-color: var(--color-primario);
  }

  /* --- TELÉFONOS Y FORMULARIO --- */
  .section-form {
    padding: 6rem 0;
    background-color: var(--color-primario-claro);
  }
  .grid-two-cols {
    display: grid;
    grid-template-columns: 1fr;
    gap: 5rem;
    align-items: start;
  }
  @media (min-width: 1024px) {
    .grid-two-cols {
      grid-template-columns: 1fr 1.4fr;
    }
  }

  .section-subtitle {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
  }
  .section-desc {
    color: #64748b;
    margin-bottom: 2.5rem;
  }

  /* Lista de Teléfonos */
  .phones-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .phone-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem;
    background: white;
    border-radius: 1.25rem;
    text-decoration: none;
    transition: all 0.3s ease;
    border: 2px solid rgba(0, 0, 0, 0.1);
  }
  .phone-item:hover {
    border-color: var(--color-primario);
    transform: translateX(5px);
    box-shadow: 0 10px 15px rgba(0, 0, 0, 0.03);
  }
  .phone-info {
    display: flex;
    flex-direction: column;
  }
  .service-name {
    font-size: 0.9rem;
    color: #64748b;
    margin-bottom: 0.2rem;
  }
  .service-number {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-primario);
  }
  .phone-circle {
    background: #f1f5f9;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primario);
    transition: 0.3s;
  }
  .phone-item:hover .phone-circle {
    background: var(--color-primario);
    color: white;
  }

  /* Formulario de Contacto */
  .contact-form-container {
    background: white;
    padding: 3.5rem;
    border-radius: 2.5rem;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.05);
    border: 2px solid rgba(0, 0, 0, 0.1);
  }
  .form-intro {
    color: #64748b;
    margin-bottom: 2.5rem;
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 640px) {
    .form-row {
      grid-template-columns: 1fr 1fr;
    }
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .form-group label {
    font-weight: 600;
    font-size: 0.9rem;
    color: #334155;
  }
  .form-group input,
  .form-group textarea {
    padding: 1rem;
    border: 1.5px solid #e2e8f0;
    border-radius: 1rem;
    font-size: 1rem;
    background: #fbfcfd;
    transition: all 0.2s;
  }
  .form-group input:focus,
  .form-group textarea:focus {
    background: white;
    border-color: var(--color-primario);
    box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1);
    outline: none;
  }

  .btn-submit {
    margin-top: 1rem;
    background: var(--color-primario);
    color: white;
    padding: 1.25rem;
    border-radius: 1rem;
    border: none;
    font-weight: 700;
    font-size: 1.1rem;
    cursor: pointer;
    transition: 0.3s;
  }
  .btn-submit:hover {
    filter: brightness(1.1);
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
  }
</style>
