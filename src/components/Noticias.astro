---
import dataNoticias from "../data/noticias.json";

const { data: cmsData } = Astro.props;
const source = (cmsData as Record<string, unknown>) ?? dataNoticias;
const noticias = (source.lista_noticias ?? dataNoticias.lista_noticias) as typeof dataNoticias.lista_noticias;
const titulo = (source.txt_titulo ?? dataNoticias.txt_titulo) as string;
const subtitulo = (source.txt_subtitulo ?? dataNoticias.txt_subtitulo) as string;
const textoVerTodo = (source.txt_ver_todo ?? dataNoticias.txt_ver_todo) as string;
const urlVerTodo = (source.link_ver_todo ?? dataNoticias.link_ver_todo) as string;

const noticiaDestacada = noticias.find((n: { boolean_destacada?: boolean }) => n.boolean_destacada) || noticias[0];
const otrasNoticias = noticias
  .filter((n: { _slug?: string }) => n._slug !== noticiaDestacada._slug) 
  .slice(0, 3);
---

<section class="noticias-section">
  <div class="container">
    <div class="header-noticias">
      <h2>{titulo}</h2>
      <p>{subtitulo}</p>
    </div>

    {
      noticiaDestacada && (
        <article class="destacada-card">
          {/* CAMBIO: id por slug */}
          <a href={`/Noticias/${noticiaDestacada._slug}`} class="destacada-link">
            <div class="destacada-img">
              <img
                src={noticiaDestacada.img_principal}
                alt={noticiaDestacada.txt_titulo}
              />
              <span class="tag-destacado">Destacada</span>
            </div>
            <div class="destacada-content">
              <span class="categoria">{noticiaDestacada.txt_categoria}</span>
              <h3>{noticiaDestacada.txt_titulo}</h3>
              <p>{noticiaDestacada.txt_extracto}</p>
              <div class="destacada-footer">
                <span class="fecha">{noticiaDestacada.txt_fecha}</span>
                <span class="leer-mas">Leer más →</span>
              </div>
            </div>
          </a>
        </article>
      )
    }

    <div class="noticias-grid">
      {
        otrasNoticias.map((noticia) => (
          <article class="noticia-card">
            {/* CAMBIO: id por slug */}
            <a href={`/Noticias/${noticia._slug}`}>
              <div class="card-img">
                <img src={noticia.img_principal} alt={noticia.txt_titulo} />
                <span class="tag-categoria">{noticia.txt_categoria}</span>
              </div>
              <div class="card-content">
                <h4>{noticia.txt_titulo}</h4>
                <p>{noticia.txt_extracto}</p>
                <span class="fecha">{noticia.txt_fecha}</span>
              </div>
            </a>
          </article>
        ))
      }
    </div>

    <div class="ver-todo-container">
      <a href={`/${urlVerTodo}`} class="btn-ver-todo">
        {textoVerTodo}
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .noticias-section {
    padding: 4rem 1rem;
    background-color: var(--color-fondo-claro);
  }
  .container {
    max-width: 1100px;
    margin: 0 auto;
  }
  .header-noticias {
    text-align: center;
    margin-bottom: 3rem;
  }
  .header-noticias h2 {
    font-size: 2.5rem;
    color: var(--color-primario);
    margin: 0 0 0.5rem 0;
  }
  .header-noticias p {
    color: var(--color-texto);
    opacity: 0.8;
  }
  .destacada-card {
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
    margin-bottom: 3rem;
    border: 1px solid var(--color-primario, #c27d0d);
  }
  .destacada-link {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    text-decoration: none;
    color: inherit;
  }
  .destacada-img {
    position: relative;
    height: 350px;
  }
  .destacada-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .tag-destacado {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: var(--color-primario, #c27d0d);
    color: white;
    padding: 0.3rem 0.8rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: bold;
  }
  .destacada-content {
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .categoria {
    color: var(--color-primario);
    font-weight: bold;
    font-size: 0.9rem;
    text-transform: uppercase;
  }
  .destacada-content h3 {
    font-size: 1.8rem;
    margin: 1rem 0;
    line-height: 1.2;
  }
  .destacada-content p {
    line-height: 1.6;
    color: #555;
    margin-bottom: 1.5rem;
  }
  .destacada-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid #eee;
    padding-top: 1rem;
  }
  .leer-mas {
    color: var(--color-primario);
    font-weight: bold;
  }
  .noticias-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }
  .noticia-card {
    background: white;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid #eee;
    transition: transform 0.3s ease;
  }
  .noticia-card a {
    text-decoration: none;
    color: inherit;
  }
  .card-img {
    position: relative;
    height: 200px;
  }
  .card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .tag-categoria {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    background: rgba(255, 255, 255, 0.9);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: bold;
    color: var(--color-primario);
  }
  .card-content {
    padding: 1.5rem;
  }
  .card-content h4 {
    margin: 0 0 0.8rem 0;
    font-size: 1.2rem;
    line-height: 1.4;
  }
  .card-content p {
    font-size: 0.9rem;
    color: #666;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 1rem;
  }
  .fecha {
    font-size: 0.8rem;
    color: #999;
  }
  .ver-todo-container {
    text-align: center;
    margin-top: 3.5rem;
  }
  .btn-ver-todo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.85rem 2rem;
    background: white;
    color: var(--color-primario, #c27d0d);
    text-decoration: none;
    border: 1px solid var(--color-primario, #c27d0d);
    border-radius: 14px;
    font-weight: 700;
    transition: all 0.3s ease;
  }
  .btn-ver-todo:hover {
    background: var(--color-primario, #c27d0d);
    border-color: var(--color-primario, #c27d0d);
    color: white;
  }
  @media (max-width: 768px) {
    .destacada-link {
      grid-template-columns: 1fr;
    }
    .destacada-img {
      height: 250px;
    }
    .destacada-content {
      padding: 1.5rem;
    }
  }
</style>
