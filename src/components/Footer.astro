---
import sitioData from "../data/sitio.json";
import { SocialIcon } from "./SocialIcon";

const {
  nombre = sitioData.txt_nombre,
  nombreCorto = sitioData.txt_nombreCorto,
  contacto = sitioData.contacto,
  listaRedes = sitioData.lista_redes,
  footer = sitioData.footer,
} = Astro.props;

const tema = sitioData._estilo;
const añoActual = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <div class="col-brand">
        <h2 class="footer-logo">{nombre}</h2>
        <p class="footer-desc">
          Trabajando cada día para construir la ciudad que soñamos. Gestión
          transparente, innovación y compromiso con cada vecino.
        </p>
        <div class="social-grid">
          {
            listaRedes?.filter((r: { link_destino?: string }) => r.link_destino).map(
              (redItem: { _red?: string; link_destino?: string }) => (
                <a
                  href={redItem.link_destino}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="social-icon"
                  aria-label={redItem._red ?? ""}
                >
                  <SocialIcon value={redItem._red ?? "otro"} size={20} />
                </a>
              ),
            )
          }
        </div>
      </div>

      <div class="col-links">
        <h3 class="footer-title">Contacto Oficial</h3>
        <ul class="contact-list">
          <li>
            <span class="contact-icon"><SocialIcon value="ubicacion" size={18} /></span>
            <a
              href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(contacto.txt_direccion)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="contact-link">{contacto.txt_direccion}</a
            >
          </li>
          <li>
            <span class="contact-icon"><SocialIcon value="telefono" size={18} /></span>
            <a
              href={`tel:${contacto.txt_telefono.replace(/\s+/g, "")}`}
              class="contact-link">{contacto.txt_telefono}</a
            >
          </li>
          <li>
            <span class="contact-icon"><SocialIcon value="mail" size={18} /></span>
            <a href={`mailto:${contacto.txt_email}`} class="contact-link"
              >{contacto.txt_email}</a
            >
          </li>
          <li>
            <span class="contact-icon"><SocialIcon value="horario" size={18} /></span>
            <span>{contacto.txt_horario}</span>
          </li>
        </ul>
      </div>

      <div class="col-action">
        <h3 class="footer-title">Atención al Vecino</h3>
        <p class="action-desc">
          ¿Tenés alguna consulta o reclamo? Utilizá nuestro sistema online.
        </p>
        <a href={footer.btn_reclamos.link_url} class="btn-reclamos-fancy">
          <span>{footer.btn_reclamos.txt_label}</span>
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"><path d="M5 12h14m-7-7 7 7-7 7"></path></svg
          >
        </a>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="bottom-content">
        <p>
          &copy; {añoActual}
          <strong>{nombreCorto}</strong>. {footer.txt_copyright}
        </p>
        <p class="dev-credit">
          Desarrollado por <a
            href="https://harvestech.dev"
            target="_blank"
            rel="noopener noreferrer">Harvestech</a
          >
        </p>
      </div>
    </div>
  </div>
</footer>

<style
  define:vars={{
    primario: tema.primario,
    primarioHover: tema.primarioHover,
    secundario: tema.secundario,
    fondoFooter: "#0f172a",
  }}
>
  .footer {
    background-color: var(--fondoFooter);
    color: #f1f5f9;
    padding: 5rem 0 2rem;
    font-family: "Inter", system-ui, sans-serif;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .footer-top {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 4rem;
    padding-bottom: 4rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-logo {
    font-size: 1.6rem;
    font-weight: 800;
    color: #fff;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
    background: linear-gradient(to right, var(--primario), #fff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .footer-desc {
    color: #94a3b8;
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .social-grid {
    display: flex;
    gap: 0.75rem;
  }

  .social-icon {
    width: 42px;
    height: 42px;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.05);
    color: #94a3b8;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .social-icon:hover {
    background: var(--primario);
    color: white;
    transform: translateY(-3px);
    border-color: transparent;
  }

  .footer-title {
    color: white;
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 1.75rem;
    position: relative;
  }

  .footer-title::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -8px;
    width: 35px;
    height: 3px;
    background: var(--primario);
  }

  .contact-list {
    list-style: none;
    padding: 0;
  }

  .contact-list li {
    display: flex;
    gap: 12px;
    margin-bottom: 1.25rem;
    color: #cbd5e1;
    font-size: 0.95rem;
    align-items: flex-start;
  }

  .contact-list svg,
  .contact-icon {
    color: var(--primario);
    flex-shrink: 0;
    margin-top: 3px;
    display: flex;
    align-items: center;
  }

  /* Estilos para los nuevos links de contacto */
  .contact-link {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .contact-link:hover {
    color: var(--primario);
  }

  .action-desc {
    color: #94a3b8;
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }

  .btn-reclamos-fancy {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: var(--primario);
    color: white;
    padding: 1rem 1.5rem;
    border-radius: 12px;
    text-decoration: none;
    font-weight: 700;
    transition: all 0.3s ease;
  }

  .btn-reclamos-fancy:hover {
    background: white;
    color: var(--secundario);
    transform: scale(1.02);
  }

  .footer-bottom {
    padding-top: 2rem;
  }

  .bottom-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    color: #64748b;
    font-size: 0.85rem;
    text-align: center;
  }

  @media (min-width: 768px) {
    .bottom-content {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }

  .bottom-content strong {
    color: var(--primario);
  }

  /* Estilo Harvestech */
  .dev-credit a {
    color: #cbd5e1;
    text-decoration: none;
    font-weight: 600;
    transition: color 0.2s ease;
  }

  .dev-credit a:hover {
    color: var(--primario);
  }
</style>
