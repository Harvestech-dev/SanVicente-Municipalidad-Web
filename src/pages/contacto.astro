---
import Layout from "../layouts/Layout.astro";
import ContactoPageClient from "../components/cms/ContactoPageClient";
import sitioData from "../data/sitio.json";

const isDevelopment =
  String(import.meta.env.ENVIRONMENT ?? import.meta.env.ENVIROMENT ?? "").toLowerCase() ===
  "development";
const clientSlug =
  String(import.meta.env.CLIENT_SLUG ?? import.meta.env.PUBLIC_CLIENT_SLUG ?? "").trim();
---

<Layout title={`Contacto | ${sitioData.txt_nombreCorto}`}>
  <ContactoPageClient client:load clientSlug={clientSlug} isDevelopment={isDevelopment} />
</Layout>
