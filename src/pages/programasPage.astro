---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import dataProgramas from "../data/programas.json";
import sitio from "../data/sitio.json";

const { txt_titulo: titulo, txt_subtitulo: subtitulo } = dataProgramas;
const tema = sitio._estilo;

interface Programa {
  _orden?: number;
  txt_nombre: string;
  txt_descripcion: string;
  link_url: string;
  _sigla?: string;
  img_fondo?: string; 
}

const programas = (dataProgramas.lista_programas as unknown) as Programa[];
---

<Layout title={`Programas | ${sitio.txt_nombreCorto}`}>
  <Header />

  <main class="main-content">
    <section class="hero-page">
      <div class="container">
        <h1>{titulo}</h1>
        <p>{subtitulo}</p>
      </div>
    </section>

    <section class="programs-list-section">
      <div class="container">
        <div class="programs-list">
          {programas.map((prog: Programa) => (
            <div class="program-banner">
              <div class="banner-image">
                {prog.img_fondo ? (
                  /* Muestra solo la imagen si existe */
                  <img src={prog.img_fondo} alt={prog.txt_nombre} loading="lazy" />
                ) : (
                  /* Si NO hay imagen, muestra el placeholder con la sigla */
                  <div class="placeholder-wrapper">
                    <div class="placeholder-img"></div>
                    <div class="logo-box-overlay">
                      <span class="sigla">{prog._sigla}</span>
                    </div>
                  </div>
                )}
              </div>

              <div class="banner-content">
                <div class="text-info">
                  <h2>{prog.txt_nombre}</h2>
                  <p>{prog.txt_descripcion}</p>
                </div>
                <div class="action-info">
                  <a href={prog.link_url} class="btn-info">
                    Ir al programa
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style define:vars={{ primary: tema.primario, texto: tema.texto }}>
  .main-content {
    background-color: #f1f5f9;
    min-height: 100vh;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .hero-page {
    background-color: var(--primary);
    color: white;
    padding: 4rem 0;
    text-align: center;
  }

  .hero-page h1 {
    font-size: clamp(2.25rem, 6vw, 3.5rem);
    font-weight: 800;
    margin-bottom: 1rem;
    letter-spacing: -0.025em;
  }

  .hero-page p {
    font-size: 1.25rem;
    opacity: 0.9;
    max-width: 650px;
    margin: 0 auto;
  }

  .programs-list-section {
    padding: 4rem 0;
  }

  .programs-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* BANNER CON ALTO FIJO  */
  .program-banner {
    display: grid;
    grid-template-columns: 320px 1fr;
    background: white;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid rgba(0, 0, 0, 0.05);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    height: 220px; /* ALTO UNIFORME PARA TODOS */
  }

  .program-banner:hover {
    transform: translateX(10px);
    border-color: var(--primary);
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
  }

  .banner-image {
    position: relative;
    height: 100%;
    background: #1f2937;
    overflow: hidden;
  }

  .banner-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .program-banner:hover .banner-image img {
    transform: scale(1.1);
  }

  .placeholder-wrapper {
    width: 100%;
    height: 100%;
    position: relative;
  }

  .placeholder-img {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #374151 0%, #111827 100%);
  }

  .logo-box-overlay {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 85px;
    height: 85px;
    background: #374151;
    border: 4px solid white;
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    box-shadow: 0 10px 20px rgba(0,0,0,0.2);
  }

  .sigla {
    font-size: 1.75rem;
    font-weight: 900;
  }

  .banner-content {
    padding: 0 3rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    height: 100%;
  }

  .text-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .text-info h2 {
    font-size: 1.6rem;
    color: var(--texto);
    margin-bottom: 0.5rem;
    font-weight: 800;
  }

  .text-info p {
    color: #475569;
    line-height: 1.5;
    font-size: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .btn-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background-color: #4b5563;
    color: white;
    padding: 0.7rem 1.5rem;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9rem;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .btn-info:hover {
    background-color: #1f2937;
  }

  @media (max-width: 850px) {
    .program-banner {
      grid-template-columns: 1fr;
      height: auto;
    }
    .banner-image {
      height: 200px;
    }
    .banner-content {
        padding: 2rem;
        flex-direction: column;
        text-align: center;
        gap: 1.5rem;
    }
    .text-info p {
      -webkit-line-clamp: 3;
    }
  }
</style>