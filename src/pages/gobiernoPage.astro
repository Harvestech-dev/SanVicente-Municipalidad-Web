---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import data from "../data/gobiernoPage/gobierno-page.json";
import sitio from "../data/sitio.json";

const { intendente, funcionarios, organigrama, titulo, descripcion } = data;
const { tema } = sitio;
---

<Layout title={`Gobierno | ${sitio.nombreCorto}`}>
  <Header />

  <main class="gobierno-container">
    <section class="hero-section">
      <div class="container">
        <h1>{titulo}</h1>
        <p>{descripcion}</p>
      </div>
    </section>

    <section class="autoridad-section">
      <div class="container">
        <div class="intendente-card">
          <div class="intendente-img">
            <img src={intendente.imagen} alt={intendente.nombre} />
          </div>
          <div class="intendente-info">
            <span class="badge">Intendencia</span>
            <h2>{intendente.nombre}</h2>
            <p class="role">{intendente.cargo}</p>
            <p class="gestion">
              <strong>Gestión:</strong>
              {intendente.gestion}
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="gabinete-section">
      <div class="container">
        <h2 class="section-title">Gabinete Municipal</h2>
        <div class="funcionarios-grid">
          {
            funcionarios.map((func) => (
              <div class="funcionario-card">
                <img src={func.imagen} alt={func.nombre} />
                <div class="funcionario-details">
                  <span class="area-tag">{func.area}</span>
                  <h3>{func.nombre}</h3>
                  <p>{func.cargo}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="organigrama-section">
      <div class="container">
        <h2 class="section-title">Organigrama</h2>
        <div class="organigrama-grid">
          {
            organigrama.map((sec) => (
              <div class="secretaria-card">
                <h3>{sec.nombre}</h3>
                <div class="divider" />
                <ul>
                  {sec.areas.map((area) => (
                    <li>
                      <span class="bullet" />
                      {area}
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style define:vars={{ primaryColor: tema.primario }}>
  /* Base & Helpers */
  .gobierno-container {
    background-color: var(--color-fondo-claro);
    min-height: 100vh;
  }

  .container {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: clamp(1rem, 4vw, 1.5rem);
  }

  /* Hero */
  .hero-section {
    background-color: var(--color-primario);
    color: var(--color-texto-claro);
    padding: clamp(3rem, 6vw, 5rem) 0 clamp(4rem, 8vw, 6rem);
    text-align: center;
  }

  .hero-section h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    margin-bottom: 1rem;
  }

  .hero-section p {
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    opacity: 0.95;
    max-width: 720px;
    margin-inline: auto;
  }

  /* Intendente */
  .autoridad-section {
    margin-top: -3.5rem;
    padding-bottom: clamp(3rem, 6vw, 4rem);
  }

  .intendente-card {
    background: var(--color-texto-claro);
    border: 1px solid color-mix(in srgb, var(--color-texto), transparent 85%);
    border-radius: 1rem;
    padding: clamp(1.75rem, 4vw, 2.5rem);
    display: flex;
    align-items: center;
    gap: clamp(1.5rem, 4vw, 2.5rem);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
  }

  .intendente-img img {
    width: clamp(140px, 30vw, 180px);
    height: clamp(140px, 30vw, 180px);
    border-radius: 9999px;
    object-fit: cover;
  }

  .badge {
    display: inline-block;
    background: color-mix(in srgb, var(--color-primario), transparent 85%);
    color: var(--color-primario);
    padding: 0.3rem 0.85rem;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.75rem;
  }

  .intendente-info h2 {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 700;
    margin: 0.5rem 0;
  }

  .role {
    font-size: 1rem;
    color: color-mix(in srgb, var(--color-texto), transparent 20%);
    margin-bottom: 1rem;
  }

  .gestion {
    font-size: 0.9rem;
    color: color-mix(in srgb, var(--color-texto), transparent 20%);
  }

  .gestion strong {
    color: var(--color-texto);
    font-weight: 600;
  }

  .contact-methods {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.5rem;
  }

  .contact-item {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: color-mix(in srgb, var(--color-texto), transparent 20%);
    text-decoration: none;
    font-size: 0.875rem;
    transition: color 0.2s ease;
  }

  .contact-item:hover {
    color: var(--color-primario);
  }

  /* Gabinete */
  .gabinete-section {
    background-color: var(--color-fondo-claro);
    padding: clamp(3rem, 6vw, 4rem) 0;
  }

  .section-title {
    text-align: center;
    font-size: clamp(1.5rem, 4vw, 1.875rem);
    font-weight: 700;
    margin-bottom: clamp(2rem, 5vw, 3rem);
    color: var(--color-texto);
  }

  .funcionarios-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 320px), 1fr));
    gap: 1.5rem;
  }

  .funcionario-card {
    background: var(--color-texto-claro);
    border: 1px solid color-mix(in srgb, var(--color-texto), transparent 70%);
    border-radius: 0.75rem;
    padding: 1.25rem;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .funcionario-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
  }

  .funcionario-card img {
    width: 72px;
    height: 72px;
    border-radius: 9999px;
    object-fit: cover;
  }

  .area-tag {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-primario);
    background: color-mix(in srgb, var(--color-primario), transparent 90%);
    padding: 0.15rem 0.6rem;
    border-radius: 4px;
  }

  .funcionario-details h3 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0.25rem 0;
  }

  .funcionario-details p {
    font-size: 0.85rem;
    color: color-mix(in srgb, var(--color-texto), transparent 10%);
  }

  /* Organigrama */
  .organigrama-section {
    padding: clamp(3rem, 6vw, 4rem) 0;
  }

  .organigrama-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 260px), 1fr));
    gap: 1.5rem;
  }

  .secretaria-card {
    background: var(--color-texto-claro);
    border: 1px solid color-mix(in srgb, var(--color-texto), transparent 65%);
    border-radius: 0.75rem;
    padding: 1.5rem;
  }

  .secretaria-card h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-primario);
    margin-bottom: 0.75rem;
  }

  .divider {
    height: 1px;
    background: color-mix(in srgb, var(--color-texto), transparent 85%);
    margin-bottom: 1rem;
  }

  .secretaria-card ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .secretaria-card li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: color-mix(in srgb, var(--color-texto), transparent 15%);
    margin-bottom: 0.5rem;
  }

  .bullet {
    width: 6px;
    height: 6px;
    background: color-mix(in srgb, var(--color-texto), transparent 60%);
    border-radius: 999px;
  }

  /* Mobile */
  @media (max-width: 640px) {
    .intendente-card {
      flex-direction: column;
      text-align: center;
    }

    .contact-methods {
      justify-content: center;
    }
  }
</style>
