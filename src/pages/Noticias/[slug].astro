---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import dataNoticias from "../../data/noticias.json";
import sitio from "../../data/sitio.json";
import { fetchNoticiasAdaptadas } from "../../lib/api-vecino";

// Rutas dinámicas: noticias desde API Vecino o JSON local
export async function getStaticPaths() {
  let noticias = await fetchNoticiasAdaptadas();
  if (noticias.length === 0) {
    noticias = dataNoticias.lista_noticias.map((n) => {
      const base = n as Record<string, unknown>;
      return { ...base, link_mas_info: (base.link_mas_info as string | null) ?? null } as (typeof noticias)[number];
    });
  }
  return noticias.map((noticia) => ({
    params: { slug: (noticia as { _slug?: string })._slug },
    props: { noticia },
  }));
}

const { noticia } = Astro.props;
const tema = sitio._estilo;
---

<Layout title={`${noticia.txt_titulo} | ${sitio.txt_nombreCorto}`}>
  <Header />

  <article class="article-page">
    <header class="article-header">
      <div class="container-narrow">
        <div class="breadcrumb">
            <a href="/noticiasPage">Noticias</a> / <span>{noticia.txt_categoria}</span>
        </div>
        <h1 class="article-title">{noticia.txt_titulo}</h1>
        <div class="article-meta">
          <span class="date">{noticia.txt_fecha}</span>
          <span class="dot">·</span>
          <span class="category">{noticia.txt_categoria}</span>
        </div>
      </div>
    </header>

    <div class="container">
      <figure class="main-figure">
        <img src={noticia.img_principal} alt={noticia.txt_titulo} class="main-image" />
      </figure>
    </div>

    <div class="article-body">
      <div class="container-narrow">
        <div class="content" set:html={noticia.txt_cuerpo} />
        
        <div class="article-footer">
          <a href="/noticiasPage" class="btn-back">
            &larr; Volver a todas las noticias
          </a>
        </div>
      </div>
    </div>
  </article>

  <Footer />
</Layout>

<style define:vars={{ primary: tema.primario }}>
  .article-page {
    padding-bottom: 5rem;
    background: #fff;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .container-narrow {
    max-width: 750px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .article-header {
    padding: 4rem 0 2.5rem;
    text-align: center;
  }

  .breadcrumb {
    font-size: 0.85rem;
    color: #64748b;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .breadcrumb a { color: var(--primary); text-decoration: none; font-weight: 600; }

  .article-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    color: #0f172a;
    margin-bottom: 1.5rem;
  }

  .article-meta {
    color: #64748b;
    font-weight: 500;
    display: flex;
    justify-content: center;
    gap: 0.5rem;
  }

  .main-figure {
    margin: 0;
    border-radius: 1.5rem;
    overflow: hidden;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
  }

  .main-image {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 16/9;
    object-fit: cover;
  }

  .article-body {
    padding-top: 4rem;
    font-size: 1.15rem;
    line-height: 1.8;
    color: #334155;
  }

  /* Estilos para el HTML inyectado (párrafos, listas, etc) */
  .content :global(p) {
    margin-bottom: 1.5rem;
  }

  .content :global(ul) {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .content :global(li) {
    margin-bottom: 0.5rem;
  }

  .article-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid #e2e8f0;
  }

  .btn-back {
    color: var(--primary);
    text-decoration: none;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    transition: transform 0.2s;
  }

  .btn-back:hover {
    transform: translateX(-5px);
  }

  @media (max-width: 768px) {
    .main-figure { border-radius: 0; margin: 0 -1.5rem; }
    .article-header { padding: 2.5rem 0 1.5rem; }
  }
</style>