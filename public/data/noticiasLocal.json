[{"id":12,"name":"MES DE LA MUJER: JORNADA DE FERIA, DEPORTES, SALUD MENTAL, M\u00daSICA Y DANZAS","extract":"En el marco de las actividades por el Mes de la Mujer, este domingo 15 de marzo se llev\u00f3 a cabo una jornada que combin\u00f3 feria, deportes, un espacio de salud mental, m\u00fasica y danzas, promoviendo el encuentro y la participaci\u00f3n comunitaria.","body":"En el marco de las actividades por el Mes de la Mujer, este domingo 15 de marzo se llev\u00f3 a cabo una jornada que combin\u00f3 feria, deportes, un espacio de salud mental, m\u00fasica y danzas, promoviendo el encuentro y la participaci\u00f3n comunitaria.\r\n\r\nLa propuesta cont\u00f3 con la participaci\u00f3n del Club Atl\u00e9tico Brown, el Club Boch\u00f3filo Bochazo, el taller de Cumbia Coreogr\u00e1fica \u201cRico y Suave\u201d, y los shows de Andar Nativo y Evelyn G\u00f3mez.","more_info":null,"landmark_id":null,"event_id":null,"published_from":"2026-03-16T03:00:00.000000Z","published_to":"2027-03-16T03:00:00.000000Z","is_important":true,"created_at":"2026-03-17T15:42:04.000000Z","updated_at":"2026-03-17T15:42:04.000000Z","deleted_at":null,"categories":[{"id":2,"name":"Cultura","category_id":null,"external_id":null,"created_at":"2026-02-13T21:38:44.000000Z","updated_at":"2026-02-13T21:38:44.000000Z","pivot":{"categorizable_id":12,"category_id":2,"categorizable_type":"App\\Models\\News"}},{"id":15,"name":"Innovaci\u00f3n y Desarrollo","category_id":null,"external_id":null,"created_at":"2026-03-17T15:15:09.000000Z","updated_at":"2026-03-17T15:15:09.000000Z","pivot":{"categorizable_id":12,"category_id":15,"categorizable_type":"App\\Models\\News"}},{"id":6,"name":"Producci\u00f3n","category_id":null,"external_id":null,"created_at":"2026-02-25T10:16:44.000000Z","updated_at":"2026-02-25T10:16:44.000000Z","pivot":{"categorizable_id":12,"category_id":6,"categorizable_type":"App\\Models\\News"}},{"id":5,"name":"Educaci\u00f3n","category_id":null,"external_id":null,"created_at":"2026-02-24T15:03