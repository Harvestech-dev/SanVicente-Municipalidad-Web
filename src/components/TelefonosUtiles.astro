---
import { SocialIcon } from "./SocialIcon";
import { normalizePageUrl } from "../lib/normalize-page-url";

interface Contacto {
  icon_contacto?: string;
  txt_label?: string;
  link_destino?: string;
  txt_valor?: string;
}

interface Telefono {
  _orden?: number;
  txt_nombre: string;
  txt_numero?: string; // formato legacy
  _icon?: string;
  lista_contactos?: Contacto[];
  lista_contacto?: Contacto[]; // API
  _color?: string;
  boolean_favorito?: boolean;
}

function getPrimerContacto(t: Telefono): {
  href: string;
  valor: string;
  icon?: string;
} {
  const contactos = (t.lista_contactos ?? t.lista_contacto ?? []) as Contacto[];
  const conLink = contactos.find(
    (c) => c.link_destino && c.link_destino.trim() !== "",
  );
  if (conLink) {
    const dest = conLink.link_destino!;
    const href = dest.startsWith("/") ? normalizePageUrl(dest) : dest;
    return {
      href: href || dest,
      valor: conLink.txt_valor ?? "",
      icon: conLink.icon_contacto,
    };
  }
  const primer = contactos[0];
  if (primer?.txt_valor) {
    const num = (primer.txt_valor ?? "").replace(/\D/g, "");
    return {
      href: `tel:${num}`,
      valor: primer.txt_valor,
      icon: primer.icon_contacto,
    };
  }
  // fallback formato legacy
  const num = (t.txt_numero ?? "").replace(/\D/g, "");
  return { href: `tel:${num}`, valor: t.txt_numero ?? "" };
}

const { data: cmsData } = Astro.props;
const source = (cmsData as Record<string, unknown>) ?? {};
const btn = source.btn_boton as
  | {
      txt_label?: string;
      label_texto?: string;
      link_destino?: string;
      link_url?: string;
      src_destino?: string;
    }
  | undefined;

const telefonos = (source.lista_telefonos ??
  source.lista_contacto ??
  []) as Telefono[];
const titulo = (source.txt_titulo ?? "") as string;
const subtitulo = (source.txt_subtitulo ?? "") as string;
const textoVerTodo = (source.txt_ver_todo ??
  btn?.txt_label ??
  btn?.label_texto ??
  "") as string;
const urlVerTodoRaw = normalizePageUrl(source.link_ver_todo ??
  btn?.link_destino ??
  btn?.link_url ??
  btn?.src_destino ??
  "");
const urlVerTodo =
  urlVerTodoRaw && urlVerTodoRaw.startsWith("/")
    ? urlVerTodoRaw
    : urlVerTodoRaw
      ? `/${urlVerTodoRaw}`
      : "";

// En home: mostrar favoritos (boolean_favorito) o, si no hay ninguno, los primeros 4 para que se vean teléfonos desde CMS
const conFavoritos = telefonos.filter((t: Telefono) => t.boolean_favorito);
const telefonosFavoritos: Telefono[] =
  conFavoritos.length > 0 ? conFavoritos.slice(0, 4) : telefonos.slice(0, 4);
const tieneMas: boolean = telefonos.length > 4;
const hayTelefonos: boolean = telefonos.length > 0;
---

{
  hayTelefonos && (
    <section class="useful-phones">
      <div class="container">
        <div class="header">
          {titulo && <h2 class="title">{titulo}</h2>}
          {subtitulo && <p class="subtitle">{subtitulo}</p>}
        </div>

        <div class="phones-grid">
          {telefonosFavoritos.map((item: Telefono) => {
            const { href, valor, icon } = getPrimerContacto(item);
            return (
              <a
                href={href}
                class="phone-card"
                target={href.startsWith("http") ? "_blank" : undefined}
                rel={
                  href.startsWith("http") ? "noopener noreferrer" : undefined
                }
              >
                <div
                  class="icon-circle"
                  style={`background-color:rgba(194,109,14,0.15); color:#C26D0E`}
                >
                  <SocialIcon iconName={item._icon ?? "FaPhone"} size={24} />
                </div>

                <h3 class="name">{item.txt_nombre}</h3>
                <span class="number">
                  <SocialIcon
                    iconName={icon ?? item._icon ?? "FaPhone"}
                    size={18}
                    className="number-icon"
                  />
                  <span class="number" style={`color:#C26D0E`}>
                    {valor}
                  </span>
                </span>
              </a>
            );
          })}
        </div>

        {tieneMas && urlVerTodo && textoVerTodo && (
          <div class="footer-action">
            <a href={urlVerTodo} class="btn-more">
              {textoVerTodo}
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="m9 18 6-6-6-6" />
              </svg>
            </a>
          </div>
        )}
      </div>
    </section>
  )
}

<style>
  .useful-phones {
    padding: 5rem 1rem;
    background-color: #f8fafc; /* gris azulado suave */
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .title {
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--color-primario, #C26D0E);
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .subtitle {
    color: #64748b;
    font-size: 1.1rem;
    max-width: 600px;
    margin: 0 auto;
  }

  .phones-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr); /* 2 columnas en móvil */
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .phones-grid {
      grid-template-columns: repeat(4, 1fr); /* 4 columnas en desktop */
      gap: 1.5rem;
    }
  }

  .phone-card {
    background: white;
    border: 1px solid rgba(226, 232, 240, 0.8);
    border-radius: 24px;
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02);
  }

  .phone-card:hover {
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05);
    border: 1px solid var(--color-primario, #c27d0d);
  }

  .icon-circle {
    width: 64px;
    height: 64px;
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    transition: all 0.3s ease;
  }

  .name {
    font-size: 0.95rem;
    font-weight: 700;
    color: #475569;
    margin-bottom: 0.5rem;
    min-height: 2.8em;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1.3;
  }

  .number {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 2rem;
    font-weight: 900;
    color: #0f172a;
    letter-spacing: -0.03em;
    line-height: 1;
  }
  .number .number-icon {
    flex-shrink: 0;
  }

  .footer-action {
    margin-top: 3.5rem;
    text-align: center;
  }

  .btn-more {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 0.85rem 2rem;
    background: white;
    border: 1px solid var(--color-primario, #c27d0d);
    border-radius: 14px;
    color: var(--color-primario, #c27d0d);
    font-weight: 700;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .btn-more:hover {
    background: var(--color-primario, #c27d0d);
    border-color: var(--color-primario, #c27d0d);
    color: white;
  }
</style>
