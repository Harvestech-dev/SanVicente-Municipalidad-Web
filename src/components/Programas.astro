---
import data from "../data/programas.json";
import sitioData from "../data/sitio.json";

interface Programa {
  _orden?: number;
  boolean_featured?: boolean;
  txt_titulo?: string;
  txt_nombre?: string;
  txt_subtitulo?: string;
  txt_descripcion?: string;
  lista_descripcion?: Array<{ txt_descripcion?: string }>;
  lista_adjuntos?: Array<{ link_url?: string }>;
  link_url?: string;
  _sigla?: string;
  img_logo?: string;
  img_fondo?: string;
  gallery_imagenes?: Array<{ img_fondo?: string }>;
}

const { data: cmsData, titulo: propTitulo, subtitulo: propSubtitulo } = Astro.props;
const source = (cmsData as Record<string, unknown>) ?? data;
const programasRaw = Array.isArray(source.lista_programas) ? source.lista_programas : (Array.isArray(data.lista_programas) ? data.lista_programas : []);
const programasSorted = [...(programasRaw as Programa[])].sort((a, b) => {
  const aF = a.boolean_featured ? 1 : 0;
  const bF = b.boolean_featured ? 1 : 0;
  return bF - aF;
});
const programas = (programasSorted.slice(0, 6) as unknown) as Programa[];
const titulo = (propTitulo ?? source.txt_titulo ?? data.txt_titulo) as string;
const subtitulo = (propSubtitulo ?? source.txt_subtitulo ?? data.txt_subtitulo) as string;
const tema = sitioData._estilo;

function getProgramaNombre(p: Programa): string {
  return p.txt_titulo ?? p.txt_nombre ?? "";
}
function getProgramaDesc(p: Programa): string {
  if (p.txt_subtitulo) return p.txt_subtitulo;
  if (p.txt_descripcion) return p.txt_descripcion;
  const first = p.lista_descripcion?.[0]?.txt_descripcion;
  return first ?? "";
}
function getProgramaUrl(p: Programa): string {
  const adj = p.lista_adjuntos?.[0]?.link_url;
  return adj ?? p.link_url ?? "/programas";
}
function getProgramaImagen(p: Programa): string {
  return p.img_logo ?? p.gallery_imagenes?.[0]?.img_fondo ?? p.img_fondo ?? "";
}
---

<section class="featured-programs">
  <div class="container">
    <div class="header">
      <h2 class="title">{titulo}</h2>
      <p class="subtitle">{subtitulo}</p>
    </div>

    <div class="programs-grid">
      {
        programas.map((prog: Programa) => (
          <a href={getProgramaUrl(prog)} class="program-card">
            <div class="logo-box">
              {getProgramaImagen(prog) ? (
                <img src={getProgramaImagen(prog)} alt={getProgramaNombre(prog)} />
              ) : (
                <span class="sigla">{prog._sigla ?? getProgramaNombre(prog).slice(0, 2).toUpperCase()}</span>
              )}
            </div>

            <div class="content">
              <h3 class="program-name">{getProgramaNombre(prog)}</h3>
              <p class="program-desc">{getProgramaDesc(prog)}</p>
            </div>
          </a>
        ))
      }
    </div>

    <div class="action-container">
      <a href="/programas" class="btn-ver-todos">
        Ver todos los programas
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </a>
    </div>
  </div>
</section>

<style
  define:vars={{
    primario: tema.primario,
    texto: tema.texto,
    fondoClaro: "#f1f5f9",
  }}
>
  .featured-programs {
    padding: 5rem 1.5rem;
    background-color: var(--fondoClaro);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .title {
    font-size: clamp(1.75rem, 5vw, 2.25rem);
    font-weight: 800;
    color: var(--primario);
    margin-bottom: 0.75rem;
  }

  .subtitle {
    font-size: 1.1rem;
    color: #64748b;
    max-width: 600px;
    margin: 0 auto;
  }

  .programs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  .program-card {
    background: white;
    border-radius: 16px;
    padding: 1.25rem;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    border: 1px solid rgba(0, 0, 0, 0.05);
    transition: all 0.3s ease;
  }

  .program-card:hover {
    border-color: var(--primario);
    box-shadow: 0 10px 20px rgba(0,0,0,0.05);
  }

  /* logo box */
  .logo-box {
    width: 60px;
    height: 60px;
    border-radius: 12px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #374151;
    color: #ffffff;
    transition: transform 0.3s ease;
  }

  .program-card:hover .logo-box {
    transform: scale(1.05);
  }

  .sigla {
    font-size: 1.2rem;
    font-weight: 800;
  }

  .logo-box img {
    width: 60%;
    height: 60%;
    object-fit: contain;
    filter: brightness(0) invert(1);
  }

  .content {
    display: flex;
    flex-direction: column;
  }

  .program-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--texto);
    margin: 0;
  }

  .program-desc {
    font-size: 0.85rem;
    color: #64748b;
    margin-top: 0.25rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /*  BOTÓN VER TODOS */
  .action-container {
    margin-top: 3.5rem;
    display: flex;
    justify-content: center;
  }

  .btn-ver-todos {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: white;
    color: var(--primario);
    padding: 0.85rem 2rem;
    border: 1px solid var(--primario);
    border-radius: 14px;
    text-decoration: none;
    font-weight: 700;
    transition: all 0.3s ease;
  }

  .btn-ver-todos:hover {
    background: var(--primario);
    border-color: var(--primario);
    color: white;
  }
</style>