# URL base API miwebcms (componentes CMS: hero_carousel, banner, etc.)
# Ejemplo: https://api.miwebcms.com/api/public/v1
# Endpoints: /client-config, /cms-components
# Sin API: hero_carousel no se muestra; resto usa fallback local
PUBLIC_API_URL=

# Solo en desarrollo: slug del cliente para ?clientSlug= en llamadas API
# Ejemplo: sanvicente
CLIENT_SLUG=

# development | production. En development se agrega ?clientSlug=CLIENT_SLUG a las llamadas
ENVIRONMENT=development

# URL base API Vecino Digital (noticias y eventos)
# Ejemplo: https://api-sanvicente.vecino.digital
# Endpoints: /citizen/news, /citizen/events
PUBLIC_API_VECINO_URL=
