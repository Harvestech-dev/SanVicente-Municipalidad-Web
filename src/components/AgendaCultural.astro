---
import agendaData from "../data/agenda-cultural.json";
import sitioData from "../data/sitio.json";
import { normalizePageUrl } from "../lib/normalize-page-url";

interface Evento {
  _orden?: number;
  txt_titulo: string;
  txt_fecha: string;
  _fechaISO?: string;
  txt_horario: string;
  txt_ubicacion: string;
  txt_categoria: string;
  img_principal: string;
}

const { data: cmsData } = Astro.props;
const source = (cmsData as Record<string, unknown>) ?? agendaData;
const btn = source.btn_boton as { txt_label?: string; label_texto?: string; link_url?: string; src_destino?: string } | undefined;

const agenda = agendaData as Record<string, unknown>;
const title = (Astro.props.title ?? source.txt_titulo ?? agenda.txt_titulo ?? "Agenda Cultural") as string;
const subtitle = (Astro.props.subtitle ?? source.txt_subtitulo ?? agenda.txt_subtitulo ?? "Descubrí los eventos y actividades en San Vicente.") as string;
const viewAllText = (Astro.props.viewAllText ?? source.txt_ver_todo ?? agenda.txt_ver_todo ?? btn?.txt_label ?? btn?.label_texto ?? "Ver toda la agenda") as string;
const viewAllHref = normalizePageUrl(Astro.props.viewAllHref ?? source.link_ver_todo ?? agenda.link_ver_todo ?? btn?.link_url ?? btn?.src_destino ?? "/agenda");

/**
 * LÓGICA DE FILTRADO Y ORDEN
 * 1. Ordenamos por _fechaISO (AAAA-MM-DD)
 * 2. .slice(0, 4) toma solo los primeros 4 eventos resultantes
 */
const listaEventos = (source.lista_eventos ?? []) as Evento[];
const eventosSorted = listaEventos
  .sort(
    (a, b) => new Date(a._fechaISO ?? a.txt_fecha).getTime() - new Date(b._fechaISO ?? b.txt_fecha).getTime(),
  );
const eventoDestacado = eventosSorted[0] ?? null;
const proximosEventos = eventosSorted.slice(1, 4);

const disclamerSinEventos = (source.lista_disclamer_sin_eventos ?? []) as { txt_parrafo?: string }[];
const ocultarSiNoHayEventos = source.boolean_ocultar_si_no_hay_eventos === true;
const hayEventos = eventoDestacado !== null;
const tema = sitioData._estilo;
---

{(!hayEventos && ocultarSiNoHayEventos) ? null : (
<section id="agenda" class="agenda-section">
  <div class="container">
    <div class="header-flex">
      <div class="title-group">
        <h2>{title}</h2>
        <p>{subtitle}</p>
      </div>
      {hayEventos && (
        <a href={viewAllHref} class="btn-outline desktop-only">
          {viewAllText}
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      )}
    </div>

    {eventoDestacado && (
      <article class="evento-destacado-card">
        <div class="evento-destacado-img">
          <img src={eventoDestacado.img_principal} alt={eventoDestacado.txt_titulo} loading="eager" />
          <span class="category-badge">{eventoDestacado.txt_categoria}</span>
        </div>
        <div class="evento-destacado-content">
          <h3>{eventoDestacado.txt_titulo}</h3>
          <div class="info-list">
            <div class="info-item">
              <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              <span>{eventoDestacado.txt_fecha}</span>
            </div>
            {String(eventoDestacado.txt_horario ?? "").trim() && (
              <div class="info-item">
                <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <span>{eventoDestacado.txt_horario}</span>
              </div>
            )}
            {String(eventoDestacado.txt_ubicacion ?? "").trim() && (
              <div class="info-item">
                <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                <span>{eventoDestacado.txt_ubicacion}</span>
              </div>
            )}
          </div>
        </div>
      </article>
    )}

    <div class="events-grid">
      {proximosEventos.length > 0 ? (
        proximosEventos.map((event: Evento) => (
          <article class="event-card">
            <div class="image-container">
              <img src={event.img_principal} alt={event.txt_titulo} loading="lazy" />
              <span class="category-badge">{event.txt_categoria}</span>
            </div>

            <div class="content">
              <h3>{event.txt_titulo}</h3>

              <div class="info-list">
                <div class="info-item">
                  <svg
                    class="icon"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <rect width="18" height="18" x="3" y="4" rx="2" ry="2" />
                    <line x1="16" y1="2" x2="16" y2="6" />
                    <line x1="8" y1="2" x2="8" y2="6" />
                    <line x1="3" y1="10" x2="21" y2="10" />
                  </svg>
                  <span>{event.txt_fecha}</span>
                </div>

                {String(event.txt_horario ?? "").trim() && (
                <div class="info-item">
                  <svg
                    class="icon"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <circle cx="12" cy="12" r="10" />
                    <polyline points="12 6 12 12 16 14" />
                  </svg>
                  <span>{event.txt_horario}</span>
                </div>
                )}
                {String(event.txt_ubicacion ?? "").trim() && (
                <div class="info-item info-item-ubicacion">
                  <span>{event.txt_ubicacion}</span>
                </div>
                )}
              </div>
            </div>
          </article>
        ))
      ) : disclamerSinEventos.length > 0 ? (
        <div class="agenda-empty">
          {disclamerSinEventos.map((p) => (
            <p>{p.txt_parrafo ?? ""}</p>
          ))}
        </div>
      ) : null}
    </div>

    {hayEventos && (
      <div class="mobile-only mt-8">
        <a href={viewAllHref} class="btn-outline full-width">
          {viewAllText}
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </div>
    )}
  </div>
</section>
)}

<style
  define:vars={{
    primary: tema.primario,
    primaryHover: tema.primarioHover,
    secondary: tema.secundario,
    text: tema.texto,
    bgClaro: tema.fondoClaro,
  }}
>
  .agenda-section * {
    box-sizing: border-box;
  }
  .agenda-section {
    padding: 5rem 1.5rem;
    background-color: var(--bgClaro);
  }
  .container {
    max-width: 1200px;
    margin: 0 auto;
  }
  .header-flex {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 3rem;
  }
  .title-group h2 {
    font-size: clamp(1.8rem, 5vw, 2.25rem);
    color: var(--primary);
    font-weight: 800;
    margin-bottom: 0.5rem;
    letter-spacing: -0.025em;
  }
  .title-group p {
    color: #64748b;
    font-size: 1.1rem;
    max-width: 500px;
  }

  .evento-destacado-card {
    background: white;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid var(--primary);
    display: grid;
    grid-template-columns: 1fr 1fr;
    margin-bottom: 2.5rem;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
  }
  .evento-destacado-img {
    position: relative;
    background: #f1f5f9;
    min-height: 300px;
  }
  .evento-destacado-img img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  .evento-destacado-img .category-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    z-index: 1;
  }
  .evento-destacado-content {
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.5rem;
  }
  .evento-destacado-content h3 {
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--secondary);
    line-height: 1.2;
    margin: 0;
  }
  @media (max-width: 768px) {
    .evento-destacado-card {
      grid-template-columns: 1fr;
    }
    .evento-destacado-img {
      min-height: 260px;
    }
    .evento-destacado-content {
      padding: 1.5rem;
    }
    .evento-destacado-content h3 {
      font-size: 1.3rem;
    }
  }

  .events-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px) {
    .events-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .events-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .event-card {
    background: white;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid rgba(0, 0, 0, 0.05);
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  .event-card:hover {
    border-color: var(--primary);
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
  }

  .image-container {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }
  .image-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .event-card:hover .image-container img {
    transform: scale(1.1);
  }

  .category-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: var(--secondary);
    color: white;
    padding: 0.4rem 0.8rem;
    border-radius: 10px;
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    z-index: 1;
  }

  .content {
    padding: 1.5rem;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }
  .content h3 {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
    color: var(--secondary);
    line-height: 1.4;
  }
  .info-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: auto;
  }
  .info-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: #475569;
    font-size: 0.9rem;
  }
  .icon {
    width: 18px;
    height: 18px;
    color: var(--primary);
    flex-shrink: 0;
  }
  .btn-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.85rem 2rem;
    border: 1px solid var(--primary);
    color: var(--primary);
    text-decoration: none;
    border-radius: 14px;
    font-weight: 700;
    transition: all 0.3s ease;
    background: white;
  }
  .btn-outline:hover {
    background: var(--primary);
    border-color: var(--primary);
    color: white;
  }

  .full-width {
    width: 100%;
  }
  .desktop-only {
    display: none;
  }
  @media (min-width: 768px) {
    .desktop-only {
      display: inline-flex;
    }
    .mobile-only {
      display: none;
    }
  }
  .mt-8 {
    margin-top: 2rem;
  }

  .agenda-empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 3rem 1.5rem;
    color: #64748b;
  }
  .agenda-empty p {
    margin: 0 0 0.5rem;
    font-size: 1.1rem;
  }
  .agenda-empty p:last-child {
    margin-bottom: 0;
  }
</style>
