---
import Layout from "../layouts/Layout.astro";
import agendaData from "../data/agenda-cultural.json";
import sitioData from "../data/sitio.json";
import { fetchEventosAdaptados } from "../lib/api-vecino";

interface Evento {
  _orden?: number;
  txt_titulo: string;
  txt_fecha: string;
  _fechaISO?: string;
  txt_horario: string;
  txt_ubicacion: string;
  txt_categoria: string;
  img_principal: string;
  txt_descripcion?: string;
}

// Solo datos de API Vecino. Sin fallback local.
const eventos = await fetchEventosAdaptados();
const hayEventos = eventos.length > 0;

const eventosOrdenados = [...eventos].sort((a, b) => {
  return new Date((a as Evento)._fechaISO ?? (a as Evento).txt_fecha).getTime() - new Date((b as Evento)._fechaISO ?? (b as Evento).txt_fecha).getTime();
});

const categorias = ["Todas", ...Array.from(new Set(eventosOrdenados.map((e) => (e as Evento).txt_categoria).filter(Boolean)))];
const disclamerEventos = (agendaData.lista_disclamer_sin_eventos ?? []) as { txt_parrafo?: string }[];
const tema = sitioData._estilo;
---

<Layout title={`Agenda Cultural | ${sitioData.txt_nombreCorto}`}>
  <main class="main-content">
    <section class="hero-agenda">
      <div class="container">
        <h1>{agendaData.txt_titulo}</h1>
        <p>{agendaData.txt_subtitulo}</p>
      </div>
    </section>

    {hayEventos && (
      <section class="filters-bar">
        <div class="container filters-flex">
          <div class="search-wrapper">
            <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="11" cy="11" r="8"/>
              <path d="m21 21-4.35-4.35"/>
            </svg>
            <input
              type="text"
              id="agenda-search"
              placeholder="Buscar eventos..."
              class="search-input"
            />
          </div>
          <div class="categories-wrapper" id="categoriesWrapper">
            {
              categorias.map((cat) => (
                <button
                  class={`btn-cat ${cat === "Todas" ? "active" : ""}`}
                  data-category={cat}
                >
                  {cat}
                </button>
              ))
            }
          </div>
        </div>
      </section>
    )}

    {hayEventos ? (
      <section class="agenda-grid-section">
        <div class="container">
          <div class="events-grid" id="eventsGrid">
            {
              eventosOrdenados.map((event) => (
              <article
                class="event-card"
                data-category={event.txt_categoria ?? ""}
                data-title={String(event.txt_titulo ?? "").toLowerCase()}
                data-ubicacion={String(event.txt_ubicacion ?? "").toLowerCase()}
                data-descripcion={String(event.txt_descripcion ?? "").toLowerCase()}
              >
                <div class="image-container">
                  <img src={event.img_principal} alt={event.txt_titulo} loading="lazy" />
                  <span class="category-badge">{event.txt_categoria}</span>
                </div>

                <div class="content">
                  <div class="text-group">
                    <h3>{event.txt_titulo}</h3>
                    <div class="info-list">
                      <div class="info-item">
                        <svg
                          class="icon"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                        >
                          <>
                            <rect
                              width="18"
                              height="18"
                              x="3"
                              y="4"
                              rx="2"
                              ry="2"
                            />
                            <line x1="16" y1="2" x2="16" y2="6" />
                            <line x1="8" y1="2" x2="8" y2="6" />
                            <line x1="3" y1="10" x2="21" y2="10" />
                          </>
                        </svg>
                        <span>{event.txt_fecha}</span>
                      </div>
                      {String(event.txt_horario ?? "").trim() && (
                      <div class="info-item">
                        <svg
                          class="icon"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                        >
                          <>
                            <circle cx="12" cy="12" r="10" />
                            <polyline points="12 6 12 12 16 14" />
                          </>
                        </svg>
                        <span>{event.txt_horario}</span>
                      </div>
                      )}
                      {String(event.txt_ubicacion ?? "").trim() && (
                      <div class="info-item info-item-ubicacion">
                        <span>{event.txt_ubicacion}</span>
                      </div>
                      )}
                    </div>
                  </div>

                  <div class="actions">
                    <button
                      class="btn-ver-imagen open-modal"
                    data-image={event.img_principal}
                    data-title={event.txt_titulo}
                    >
                      <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                      >
                        <>
                          <path d="M15 3h6v6" />
                          <path d="M10 14 21 3" />
                          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                        </>
                      </svg>
                      Ver imagen
                    </button>
                  </div>
                </div>
              </article>
            ))
            }
          </div>
        </div>
      </section>
    ) : (
      <section class="section-disclaimer">
        <div class="container">
          <div class="disclaimer-content">
            {disclamerEventos.map((p) => (
              <p>{p.txt_parrafo ?? ""}</p>
            ))}
          </div>
        </div>
      </section>
    )}
  </main>

  <div id="imageModal" class="modal">
    <div class="modal-overlay"></div>
    <div class="modal-container">
      <button class="modal-close" aria-label="Cerrar">&times;</button>
      <img id="modalImg" src="" alt="Vista previa" />
      <div id="modalTitle" class="modal-caption"></div>
    </div>
  </div>
</Layout>

<script define:vars={{ eventos, eventosOrdenados, hayEventos, categorias }}>
  if (typeof window !== "undefined") {
    console.log("[API] Página Agenda - Toda la información:", {
      vecino: { eventos, eventosOrdenados, hayEventos, categorias },
    });
  }
</script>
<script>
  const modal = document.getElementById("imageModal");
  const modalImg = document.getElementById("modalImg") as HTMLImageElement;
  const modalTitle = document.getElementById("modalTitle");
  const closeBtn = document.querySelector(".modal-close");
  const overlay = document.querySelector(".modal-overlay");
  const openButtons = document.querySelectorAll(".open-modal");

  openButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const imgSrc = btn.getAttribute("data-image");
      const title = btn.getAttribute("data-title");
      if (imgSrc && modal && modalImg) {
        modalImg.src = imgSrc;
        if (modalTitle) modalTitle.textContent = title;
        modal.classList.add("active");
        document.body.style.overflow = "hidden";
      }
    });
  });

  const closeModal = () => {
    modal?.classList.remove("active");
    document.body.style.overflow = "auto";
  };

  closeBtn?.addEventListener("click", closeModal);
  overlay?.addEventListener("click", closeModal);
  window.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal();
  });

  // --- Filtros y búsqueda ---
  const eventsGrid = document.getElementById("eventsGrid");
  const eventCards = Array.from(eventsGrid?.querySelectorAll(".event-card") || []) as HTMLElement[];
  const categoryButtons = document.querySelectorAll(".btn-cat") as NodeListOf<HTMLButtonElement>;
  const searchInput = document.getElementById("agenda-search") as HTMLInputElement;

  let currentCategory = "Todas";
  let searchQuery = "";

  function matchesSearch(card: HTMLElement): boolean {
    if (!searchQuery.trim()) return true;
    const q = searchQuery.toLowerCase();
    const title = card.getAttribute("data-title") || "";
    const ubicacion = card.getAttribute("data-ubicacion") || "";
    const descripcion = card.getAttribute("data-descripcion") || "";
    return title.includes(q) || ubicacion.includes(q) || descripcion.includes(q);
  }

  function updateDisplay(): void {
    eventCards.forEach((card) => {
      const category = card.getAttribute("data-category") || "";
      const matchesCat = currentCategory === "Todas" || category === currentCategory;
      const matches = matchesCat && matchesSearch(card);
      card.style.display = matches ? "" : "none";
    });
  }

  categoryButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      categoryButtons.forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      currentCategory = btn.getAttribute("data-category") || "Todas";
      updateDisplay();
    });
  });

  searchInput?.addEventListener("input", (e) => {
    const target = e.target as HTMLInputElement;
    searchQuery = target?.value ?? "";
    updateDisplay();
  });
</script>

<style
  define:vars={{
    primary: tema.primario,
    secondary: tema.secundario,
    text: tema.texto,
  }}
>
  .main-content {
    background-color: #f8fafc;
    min-height: 100vh;
  }
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .hero-agenda {
    background-color: var(--primary);
    color: white;
    padding: 4rem 0;
    text-align: center;
  }
  .hero-agenda h1 {
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    font-weight: 800;
    margin-bottom: 1rem;
  }
  .hero-agenda p {
    font-size: 1.2rem;
    opacity: 0.9;
  }

  /* --- Barra de filtros --- */
  .filters-bar {
    background: #ffffff;
    border-bottom: 1px solid #e2e8f0;
    padding: 1.5rem 0;
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .filters-flex {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .filters-bar .search-wrapper {
    flex: 1;
    min-width: 200px;
    position: relative;
    display: flex;
    align-items: center;
  }
  .filters-bar .search-wrapper .search-icon {
    position: absolute;
    left: 1rem;
    color: var(--primary);
    pointer-events: none;
  }
  .filters-bar .search-input {
    padding: 0.6rem 1rem 0.6rem 2.5rem;
    border: 1px solid #e2e8f0;
    border-radius: 0.5rem;
    width: 100%;
    max-width: 300px;
    min-height: 40px;
    box-sizing: border-box;
  }
  .filters-bar .search-input:focus {
    outline: none;
    border-color: var(--primary);
  }
  .categories-wrapper {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .btn-cat {
    padding: 0.5rem 1rem;
    border-radius: 99px;
    border: 1px solid #e2e8f0;
    background: transparent;
    cursor: pointer;
    font-size: 0.875rem;
    transition: all 0.2s;
  }
  .btn-cat.active {
    background: var(--primary);
    color: white;
    border-color: var(--primary);
  }

  .agenda-grid-section {
    padding: 4rem 0;
  }
  .events-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }

  .event-card {
    background: white;
    border-radius: 24px;
    overflow: hidden;
    border: 1px solid rgba(0, 0, 0, 0.05);
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: all 0.3s ease;
  }
  .event-card:hover {
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
  }

  .image-container {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }
  .image-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .category-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: var(--primary);
    color: white;
    padding: 0.4rem 0.8rem;
    border-radius: 8px;
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    flex-grow: 1;
  }
  .text-group h3 {
    font-size: 1.25rem;
    color: var(--secondary);
    font-weight: 800;
    margin-bottom: 1rem;
  }
  .info-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .info-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: #475569;
    font-size: 0.95rem;
  }
  .icon {
    width: 18px;
    height: 18px;
    color: var(--primary);
  }
  .actions {
    margin-top: auto;
    padding-top: 1.5rem;
  }
  .btn-ver-imagen {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background-color: #4b5563;
    color: white;
    border: none;
    padding: 0.8rem;
    border-radius: 12px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  .btn-ver-imagen:hover {
    background-color: #1f2937;
  }

  /* MODAL STYLES */
  .modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 2000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
  }
  .modal.active {
    opacity: 1;
    visibility: visible;
  }
  .modal-overlay {
    position: absolute;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(4px);
  }
  .modal-container {
    position: relative;
    max-width: 90%;
    max-height: 85vh;
    z-index: 2001;
  }
  .modal-container img {
    max-width: 100%;
    max-height: 75vh;
    border-radius: 12px;
    border: 4px solid white;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
  }
  .modal-close {
    position: absolute;
    top: -50px;
    right: 0;
    background: none;
    border: none;
    color: white;
    font-size: 40px;
    cursor: pointer;
  }
  .modal-caption {
    color: white;
    margin-top: 1rem;
    font-weight: 700;
    font-size: 1.2rem;
    text-align: center;
  }

  .section-disclaimer {
    padding: 4rem 0;
  }
  .disclaimer-content {
    text-align: center;
    color: #64748b;
  }
  .disclaimer-content p {
    margin: 0 0 0.5rem;
    font-size: 1.1rem;
  }
  .disclaimer-content p:last-child {
    margin-bottom: 0;
  }
</style>
