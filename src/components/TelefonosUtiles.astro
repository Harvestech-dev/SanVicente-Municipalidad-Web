---
import data from "../data/telefonos.json";

interface Telefono {
  id: number;
  nombre: string;
  numero: string;
  icon: string;
  color: string;
  prioridad: number;
}

const { 
  telefonos = data.telefonos as Telefono[], 
  titulo = data.titulo, 
  subtitulo = data.subtitulo,
  maxDisplay = data.maxHomeDisplay,
  textoVerTodo = data.textoVerTodo,
  urlVerTodo = data.urlVerTodo
} = Astro.props;

const telefonosOrdenados = [...telefonos]
  .sort((a, b) => a.prioridad - b.prioridad)
  .slice(0, maxDisplay);

const tieneMas = telefonos.length > maxDisplay;

const iconos: Record<string, string> = {
  hospital: `<path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path><rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect><path d="M12 11h4"></path><path d="M12 11v4"></path><path d="M12 11H8"></path><path d="M12 11V7"></path>`,
  shield: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>`,
  flame: `<path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"></path>`,
  alert: `<path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line>`,
  phone: `<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>`
};
---

<section class="useful-phones">
  <div class="container">
    <div class="header">
      <h2 class="title">{titulo}</h2>
      <p class="subtitle">{subtitulo}</p>
    </div>

    <div class="phones-grid">
      {telefonosOrdenados.map((item) => (
        <a href={`tel:${item.numero.replace(/\D/g, '')}`} class="phone-card">
          <div class="icon-circle" style={`background-color: ${item.color}15; color: ${item.color}`}>
            <svg 
              width="24" 
              height="24" 
              viewBox="0 0 24 24" 
              fill="none" 
              stroke="currentColor" 
              stroke-width="2.5" 
              stroke-linecap="round" 
              stroke-linejoin="round"
              set:html={iconos[item.icon] || iconos.phone}
            />
          </div>
          <h3 class="name">{item.nombre}</h3>
          <span class="number">{item.numero}</span>
        </a>
      ))}
    </div>

    {tieneMas && (
      <div class="footer-action">
        <a href={urlVerTodo} class="btn-more">
          {textoVerTodo}
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </div>
    )}
  </div>
</section>

<style>
  .useful-phones {
    padding: 5rem 1rem;
    background-color: #f8fafc; /* Un gris azulado muy suave */
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .title {
    font-size: 2.25rem;
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .subtitle {
    color: #64748b;
    font-size: 1.1rem;
    max-width: 600px;
    margin: 0 auto;
  }

  .phones-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr); /* 2 columnas en móvil */
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .phones-grid {
      grid-template-columns: repeat(4, 1fr); /* 4 columnas en desktop */
      gap: 1.5rem;
    }
  }

  .phone-card {
    background: white;
    border: 1px solid rgba(226, 232, 240, 0.8);
    border-radius: 24px;
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02);
  }

  .phone-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05);
    border-color: #cbd5e1;
  }

  .icon-circle {
    width: 64px;
    height: 64px;
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    transition: all 0.3s ease;
  }

  .phone-card:hover .icon-circle {
    transform: scale(1.1) rotate(-5deg);
  }

  .name {
    font-size: 0.95rem;
    font-weight: 700;
    color: #475569;
    margin-bottom: 0.5rem;
    min-height: 2.8em;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1.3;
  }

  .number {
    font-size: 2rem;
    font-weight: 900;
    color: #0f172a;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .footer-action {
    margin-top: 3.5rem;
    text-align: center;
  }

  .btn-more {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 0.85rem 2rem;
    background: white;
    border: 2px solid #e2e8f0;
    border-radius: 14px;
    color: #475569;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .btn-more:hover {
    background: #0f172a;
    border-color: #0f172a;
    color: white;
  }
</style>