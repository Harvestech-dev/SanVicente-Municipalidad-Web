---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import data from "../data/gobiernoPage/gobierno-page.json";
import sitio from "../data/sitio.json";

const { intendente, lista_funcionarios: funcionarios, lista_organigrama: organigrama, txt_titulo: titulo, txt_descripcion: descripcion } = data;
const tema = sitio._estilo;

const defaultProfile = "/profile.png";
---

<Layout title={`Gobierno | ${sitio.txt_nombreCorto}`}>
  <Header />

  <main class="gobierno-container">
    <section class="hero-section">
      <div class="container">
        <h1>{titulo}</h1>
        <p>{descripcion}</p>
      </div>
    </section>

    <section class="autoridad-section">
      <div class="container">
        <div class="intendente-card">
          <div class="intendente-img">
            <img
            src={intendente.img_perfil || defaultProfile}
            alt={intendente.txt_nombre}
            />
          </div>
          <div class="intendente-info">
            <span class="badge">Intendencia</span>
            <h2>{intendente.txt_nombre}</h2>
            <p class="role">{intendente.txt_cargo}</p>
            <p class="gestion">
              <strong>Gestión:</strong>
              {intendente.txt_gestion}
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="gabinete-section">
      <div class="container">
        <h2 class="section-title">Gabinete Municipal</h2>
        <div class="funcionarios-flex">
          {
            funcionarios.map((func) => (
              <div class="funcionario-card">
                <img src={func.img_perfil || defaultProfile} alt={func.txt_nombre} />
                <div class="funcionario-details">
                  <span class="area-tag">{func.txt_area}</span>
                  <h3>{func.txt_nombre}</h3>
                  <p>{func.txt_cargo}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="organigrama-section">
      <div class="container">
        <h2 class="section-title">Organigrama</h2>
        <div class="organigrama-flex">
          {
            organigrama.map((sec) => (
              <div class="secretaria-card">
                <h3>{sec.txt_nombre}</h3>
                <div class="divider" />
                <ul>
                  {sec.lista_areas?.map((area: string) => (
                    <li>
                      <span class="bullet" />
                      {area}
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style define:vars={{ primaryColor: tema.primario }}>
  .gobierno-container {
    background-color: var(--color-fondo-claro);
    min-height: 100vh;
  }
  .container {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: clamp(1rem, 4vw, 1.5rem);
  }

  /* Hero */
  .hero-section {
    background-color: var(--color-primario);
    color: var(--color-texto-claro);
    padding: clamp(3rem, 6vw, 5rem) 0 clamp(4rem, 8vw, 6rem);
    text-align: center;
  }
  .hero-section h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    margin-bottom: 1rem;
  }
  .hero-section p {
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    opacity: 0.95;
    max-width: 720px;
    margin-inline: auto;
  }

  /* --- INTENDENTE (CAMBIOS SOLICITADOS) --- */
  .autoridad-section {
    margin-top: -4rem; /* Un poco más de solapado */
    padding-bottom: clamp(3rem, 6vw, 4rem);
    position: relative;
    z-index: 10;
  }
  .intendente-card {
    background: var(--color-texto-claro);
    /* Borde lateral con color primario para dar color */
    border: 1px solid var(--color-primario);

    border-radius: 1rem;
    padding: clamp(1.75rem, 4vw, 2.5rem);
    display: flex;
    align-items: center;
    gap: clamp(1.5rem, 4vw, 2.5rem);

    /* Sombra con un toque de color primario */
    box-shadow: 0 15px 35px
      color-mix(in srgb, var(--color-primario), transparent 85%);
  }
  .intendente-img img {
    width: clamp(150px, 30vw, 200px);
    height: clamp(150px, 30vw, 200px);
    border-radius: 9999px;
    object-fit: cover;

    /* Anillo de color en la foto */
    padding: 5px;
    border: 2px solid color-mix(in srgb, var(--color-primario), transparent 70%);
    background: white;
  }
  .badge {
    display: inline-block;
    background: var(--color-primario);
    color: white;
    padding: 0.3rem 0.8rem;
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }
  .intendente-info h2 {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    margin: 0;
    color: #1a1a1a;
  }
  .role {
    color: var(--color-primario);
    font-weight: 700;
    margin-bottom: 1rem;
    font-size: 1.1rem;
  }
  .gestion {
    border-top: 1px solid
      color-mix(in srgb, var(--color-primario), transparent 90%);
    padding-top: 1rem;
  }

  /* Gabinete & Organigrama */
  .gabinete-section,
  .organigrama-section {
    margin-bottom: 4rem;
  }

  .funcionarios-flex,
  .organigrama-flex {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    justify-content: center;
  }

  .funcionario-card {
    background: var(--color-texto-claro);
    border: 1px solid color-mix(in srgb, var(--color-texto), transparent 70%);
    &:hover {
      border: 1px solid var(--color-primario);
    }
    border-radius: 0.75rem;
    padding: 1.25rem;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex: 0 1 340px;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border 0.2s ease;
  }

  .secretaria-card {
    background: var(--color-texto-claro);
    border: 1px solid color-mix(in srgb, var(--color-texto), transparent 65%);
    border-radius: 0.75rem;
    padding: 1.5rem;
    flex: 0 1 280px;
  }

  .funcionario-card:hover {
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
  }
  .funcionario-card img {
    width: 72px;
    height: 72px;
    border-radius: 9999px;
    object-fit: cover;
    background: #eee;
  }
  .area-tag {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-primario);
    background: color-mix(in srgb, var(--color-primario), transparent 90%);
    padding: 0.15rem 0.6rem;
    border-radius: 4px;
  }
  .funcionario-details h3 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0.25rem 0;
  }
  .funcionario-details p {
    font-size: 0.85rem;
    color: color-mix(in srgb, var(--color-texto), transparent 10%);
  }
  .section-title {
    text-align: center;
    font-size: clamp(1.5rem, 4vw, 1.875rem);
    font-weight: 700;
    margin-bottom: clamp(2rem, 5vw, 3rem);
    color: var(--color-texto);
    margin-top: 4rem;
  }
  .divider {
    height: 1px;
    background: color-mix(in srgb, var(--color-texto), transparent 85%);
    margin-bottom: 1rem;
  }
  .secretaria-card h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-primario);
    margin-bottom: 0.75rem;
  }
  .secretaria-card ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .secretaria-card li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: color-mix(in srgb, var(--color-texto), transparent 15%);
    margin-bottom: 0.5rem;
  }
  .bullet {
    width: 6px;
    height: 6px;
    background: color-mix(in srgb, var(--color-texto), transparent 60%);
    border-radius: 999px;
  }

  /* Mobile */
  @media (max-width: 640px) {
    .intendente-card {
      flex-direction: column;
      text-align: center;
    }
    .funcionario-card {
      flex: 1 1 100%;
    }
    .secretaria-card {
      flex: 1 1 100%;
    }
  }
</style>
