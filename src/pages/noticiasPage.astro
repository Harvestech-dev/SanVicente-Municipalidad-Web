---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import dataNoticias from "../data/noticias.json";
import sitio from "../data/sitio.json";
import { fetchNoticiasAdaptadas } from "../lib/api-vecino";

// 1. Intentar API Vecino; fallback a JSON local (normalizar para mismo formato)
let noticias = await fetchNoticiasAdaptadas();
if (noticias.length === 0) {
  noticias = dataNoticias.lista_noticias.map((n) => {
    const base = n as Record<string, unknown>;
    return { ...base, link_mas_info: (base.link_mas_info as string | null) ?? null } as (typeof noticias)[number];
  });
}

let categorias = ["Todas", ...Array.from(new Set(noticias.map((n) => (n as { txt_categoria?: string }).txt_categoria).filter(Boolean)))];
if (categorias.length <= 1) {
  categorias = dataNoticias.lista_categorias;
}

const titulo = dataNoticias.txt_titulo;
const subtitulo = dataNoticias.txt_subtitulo;
const tema = sitio._estilo;

const noticiaDestacada = noticias.find((n: { boolean_destacada?: boolean }) => n.boolean_destacada) || noticias[0];
const todasLasNoticias = noticias;
---

<Layout title={`Noticias | ${sitio.txt_nombreCorto}`}>
  <Header />

  <main class="main-content">
    <section class="hero-noticias">
      <div class="container">
        <h1>{titulo}</h1>
        <p>{subtitulo}</p>
      </div>
    </section>

    <section class="filters-bar">
      <div class="container filters-flex">
        <div class="search-wrapper">
          <input
            type="text"
            id="searchInput"
            placeholder="Buscar noticias..."
            class="search-input"
          />
        </div>
        <div class="categories-wrapper" id="categoriesWrapper">
          {
            categorias.map((cat) => (
              <button
                class={`btn-cat ${cat === "Todas" ? "active" : ""}`}
                data-category={cat}
              >
                {cat}
              </button>
            ))
          }
        </div>
      </div>
    </section>

    {
      noticiaDestacada && (
        <section class="featured-news" id="featuredSection">
          <div class="container">
            <a
              href={`/Noticias/${noticiaDestacada._slug}`}
              class="featured-card"
            >
              <div class="featured-image">
                <img
                  src={noticiaDestacada.img_principal}
                  alt={noticiaDestacada.txt_titulo}
                />
                <span class="badge-destacada">Destacada</span>
              </div>
              <div class="featured-info">
                <span class="category-tag">{noticiaDestacada.txt_categoria}</span>
                <h2>{noticiaDestacada.txt_titulo}</h2>
                <p>{noticiaDestacada.txt_extracto}</p>
                <div class="featured-footer">
                  <span class="date">{noticiaDestacada.txt_fecha}</span>
                  <span class="read-more">Leer más &rarr;</span>
                </div>
              </div>
            </a>
          </div>
        </section>
      )
    }

    <section class="news-list">
      <div class="container">
        <div class="news-grid" id="newsGrid">
          {
            (todasLasNoticias ?? []).filter((n) => n && n.txt_titulo).map((noticia) => (
              <a
                href={`/Noticias/${noticia._slug}`}
                class="news-card"
                data-category={noticia.txt_categoria ?? ""}
                data-title={String(noticia.txt_titulo ?? "").toLowerCase()}
                data-destacada={noticia.boolean_destacada ? "true" : "false"}
              >
                <div class="card-image">
                  <img src={noticia.img_principal} alt={noticia.txt_titulo} />
                  <span class="card-category">{noticia.txt_categoria}</span>
                </div>
                <div class="card-content">
                  <h3>{noticia.txt_titulo}</h3>
                  <p>{noticia.txt_extracto}</p>
                  <span class="card-date">{noticia.txt_fecha}</span>
                </div>
              </a>
            ))
          }
        </div>

        <div class="pagination" id="pagination"></div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  // --- Lógica de Filtros, Búsqueda y Paginación ---

  // Configuración de paginación
  const ITEMS_PER_PAGE = 6;
  let currentPage = 1;
  let currentCategory: string = "Todas";
  let searchQuery: string = "";

  const newsGrid = document.getElementById('newsGrid') as HTMLDivElement;
  const featuredSection = document.getElementById('featuredSection') as HTMLElement | null;
  const cards = Array.from(newsGrid?.querySelectorAll('.news-card') || []) as HTMLAnchorElement[];
  const categoryButtons = document.querySelectorAll('.btn-cat') as NodeListOf<HTMLButtonElement>;
  const searchInput = document.getElementById('searchInput') as HTMLInputElement;
  const paginationContainer = document.getElementById('pagination') as HTMLDivElement;

  function updateDisplay(): void {
    if (!newsGrid) return;

    const isFiltering = currentCategory !== "Todas" || searchQuery !== "";

    if (featuredSection) {
      featuredSection.style.display = isFiltering ? "none" : "block";
    }

    const filteredCards = cards.filter(card => {
      const category = card.getAttribute('data-category') || "";
      const title = card.getAttribute('data-title') || "";
      const isDestacada = card.getAttribute('data-destacada') === "true";
      
      const matchesCategory = currentCategory === "Todas" || category === currentCategory;
      const matchesSearch = title.includes(searchQuery.toLowerCase());
      
      if (!isFiltering && isDestacada) return false;
      return matchesCategory && matchesSearch;
    });

    const totalPages = Math.ceil(filteredCards.length / ITEMS_PER_PAGE);
    
    // Ocultar todas
    cards.forEach(card => {
      card.style.display = 'none';
    });

    const start = (currentPage - 1) * ITEMS_PER_PAGE;
    const end = start + ITEMS_PER_PAGE;
    
    filteredCards.slice(start, end).forEach(card => {
      card.style.display = 'block';
    });

    renderPagination(totalPages);
  }

  function renderPagination(totalPages: number): void {
    if (!paginationContainer) return;
    
    paginationContainer.innerHTML = '';
    if (totalPages <= 1) return;

    for (let i = 1; i <= totalPages; i++) {
      const btn = document.createElement('button');
      btn.innerText = i.toString(); // Convertimos número a string
      if (i === currentPage) btn.classList.add('active');
      
      btn.onclick = () => {
        currentPage = i;
        updateDisplay();
        window.scrollTo({ top: newsGrid.offsetTop - 150, behavior: 'smooth' });
      };
      paginationContainer.appendChild(btn);
    }
  }

  categoryButtons.forEach(btn => {
    btn.onclick = () => {
      categoryButtons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentCategory = btn.getAttribute('data-category') || "Todas";
      currentPage = 1;
      updateDisplay();
    };
  });

  if (searchInput) {
    searchInput.oninput = (e: Event) => {
      const target = e.target as HTMLInputElement;
      searchQuery = target ? target.value : "";
      currentPage = 1;
      updateDisplay();
    };
  }

  // Ejecución inicial
  updateDisplay();
</script>

<style define:vars={{ primary: tema.primario, secondary: tema.secundario }}>
  /* --- Estructura y Hero --- */
  .main-content {
    min-height: 100vh;
    background-color: #ffffff;
  }
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .hero-noticias {
    background-color: var(--primary);
    color: #ffffff;
    padding: 4rem 0;
    text-align: center;
  }
  .hero-noticias h1 {
    font-size: 3rem;
    font-weight: 800;
    margin-bottom: 1rem;
  }
  .hero-noticias p {
    font-size: 1.2rem;
    opacity: 0.9;
  }

  /* --- Barra de Filtros --- */
  .filters-bar {
    background: #ffffff;
    border-bottom: 1px solid #e2e8f0;
    padding: 1.5rem 0;
    sticky: top;
    top: 0;
    z-index: 10;
  }
  .filters-flex {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .search-input {
    padding: 0.6rem 1rem;
    border: 1px solid #e2e8f0;
    border-radius: 0.5rem;
    width: 100%;
    max-width: 300px;
  }
  .categories-wrapper {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .btn-cat {
    padding: 0.5rem 1rem;
    border-radius: 99px;
    border: 1px solid #e2e8f0;
    background: transparent;
    cursor: pointer;
    font-size: 0.875rem;
    transition: all 0.2s;
  }
  .btn-cat.active {
    background: var(--primary);
    color: white;
    border-color: var(--primary);
  }

  /* --- Card Destacada (Especial) --- */
  .featured-news {
    padding: 3rem 0;
    background-color: #f8fafc;
  }
  .featured-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: white;
    border-radius: 1rem;
    overflow: hidden;
    border: 1px solid #e2e8f0;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s ease;
  }
  .featured-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);
  }
  .featured-image {
    position: relative;
    min-height: 350px;
  }
  .featured-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .badge-destacada {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: var(--secondary);
    color: white;
    padding: 0.25rem 0.75rem;
    border-radius: 99px;
    font-weight: bold;
    font-size: 0.75rem;
  }
  .featured-info {
    padding: 3rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .category-tag {
    color: var(--primary);
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .featured-info h2 {
    font-size: 2.25rem;
    font-weight: 800;
    margin-bottom: 1rem;
    line-height: 1.2;
  }
  .featured-info p {
    color: #64748b;
    line-height: 1.6;
    margin-bottom: 2rem;
  }
  .featured-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .read-more {
    font-weight: 600;
    color: var(--primary);
  }

  /* --- Grilla de Noticias --- */
  .news-list {
    padding: 4rem 0;
  }
  .news-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
  }
  .news-card {
    background: white;
    border-radius: 1rem;
    border: 1px solid #e2e8f0;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: all 0.3s ease;
  }
  .news-card:hover {
    border-color: var(--primary);
    transform: translateY(-4px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);
  }
  .card-image {
    position: relative;
    aspect-ratio: 16 / 9;
  }
  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .card-category {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: rgba(255, 255, 255, 0.9);
    color: var(--primary);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: bold;
  }
  .card-content {
    padding: 1.5rem;
  }
  .card-content h3 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    line-height: 1.4;
  }
  .card-content p {
    font-size: 0.9rem;
    color: #64748b;
    margin-bottom: 1.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-date {
    font-size: 0.75rem;
    color: #94a3b8;
  }

  /* --- Paginación --- */
  .pagination {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 3rem;
  }
  .pagination :global(button) {
    padding: 0.5rem 1rem;
    border: 1px solid #e2e8f0;
    background: white;
    border-radius: 0.5rem;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.2s;
  }
  .pagination :global(button.active) {
    background: var(--primary);
    color: white;
    border-color: var(--primary);
  }

  @media (max-width: 768px) {
    .featured-card {
      grid-template-columns: 1fr;
    }
    .featured-image {
      min-height: 250px;
    }
    .hero-noticias h1 {
      font-size: 2.25rem;
    }
    .filters-flex {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
