---
import dataNoticias from "../data/noticias.json";

const { noticias, titulo, subtitulo, textoVerTodo, urlVerTodo } = dataNoticias;

// Lógica de datos
const noticiaDestacada = noticias.find((n) => n.destacada) || noticias[0];
const otrasNoticias = noticias
  .filter((n) => n.id !== noticiaDestacada.id)
  .slice(0, 3);
---

<section class="noticias-section">
  <div class="container">
    <div class="header-noticias">
      <h2>{titulo}</h2>
      <p>{subtitulo}</p>
    </div>

    {
      noticiaDestacada && (
        <article class="destacada-card">
          <a href={`/noticias/${noticiaDestacada.id}`} class="destacada-link">
            <div class="destacada-img">
              <img
                src={noticiaDestacada.imagen}
                alt={noticiaDestacada.titulo}
              />
              <span class="tag-destacado">Destacada</span>
            </div>
            <div class="destacada-content">
              <span class="categoria">{noticiaDestacada.categoria}</span>
              <h3>{noticiaDestacada.titulo}</h3>
              <p>{noticiaDestacada.extracto}</p>
              <div class="destacada-footer">
                <span class="fecha">{noticiaDestacada.fecha}</span>
                <span class="leer-mas">Leer más →</span>
              </div>
            </div>
          </a>
        </article>
      )
    }

    <div class="noticias-grid">
      {
        otrasNoticias.map((noticia) => (
          <article class="noticia-card">
            <a href={`/noticias/${noticia.id}`}>
              <div class="card-img">
                <img src={noticia.imagen} alt={noticia.titulo} />
                <span class="tag-categoria">{noticia.categoria}</span>
              </div>
              <div class="card-content">
                <h4>{noticia.titulo}</h4>
                <p>{noticia.extracto}</p>
                <span class="fecha">{noticia.fecha}</span>
              </div>
            </a>
          </article>
        ))
      }
    </div>

    <div class="ver-todo-container">
      <a href={`/${urlVerTodo}`} class="btn-ver-todo">
        {textoVerTodo}
      </a>
    </div>
  </div>
</section>

<style>
  /* Contenedor General */
  .noticias-section {
    padding: 4rem 1rem;
    background-color: var(--color-fondo-claro);
  }
  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  /* Header */
  .header-noticias {
    text-align: center;
    margin-bottom: 3rem;
  }
  .header-noticias h2 {
    font-size: 2.5rem;
    color: var(--color-primario);
    margin: 0 0 0.5rem 0;
  }
  .header-noticias p {
    color: var(--color-texto);
    opacity: 0.8;
  }

  /* Card Destacada */
  .destacada-card {
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
    margin-bottom: 3rem;
    border: 1px solid #eee;
  }
  .destacada-link {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    text-decoration: none;
    color: inherit;
  }
  .destacada-img {
    position: relative;
    height: 350px;
  }
  .destacada-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .tag-destacado {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: var(--color-secundario);
    color: white;
    padding: 0.3rem 0.8rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: bold;
  }
  .destacada-content {
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .categoria {
    color: var(--color-primario);
    font-weight: bold;
    font-size: 0.9rem;
    text-transform: uppercase;
  }
  .destacada-content h3 {
    font-size: 1.8rem;
    margin: 1rem 0;
    line-height: 1.2;
  }
  .destacada-content p {
    line-height: 1.6;
    color: #555;
    margin-bottom: 1.5rem;
  }
  .destacada-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid #eee;
    padding-top: 1rem;
  }
  .leer-mas {
    color: var(--color-primario);
    font-weight: bold;
  }

  /* Grilla Secundaria */
  .noticias-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }
  .noticia-card {
    background: white;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid #eee;
    transition: transform 0.3s ease;
  }
  .noticia-card:hover {
    transform: translateY(-5px);
  }
  .noticia-card a {
    text-decoration: none;
    color: inherit;
  }
  .card-img {
    position: relative;
    height: 200px;
  }
  .card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .tag-categoria {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    background: rgba(255, 255, 255, 0.9);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: bold;
    color: var(--color-primario);
  }
  .card-content {
    padding: 1.5rem;
  }
  .card-content h4 {
    margin: 0 0 0.8rem 0;
    font-size: 1.2rem;
    line-height: 1.4;
  }
  .card-content p {
    font-size: 0.9rem;
    color: #666;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 1rem;
  }
  .fecha {
    font-size: 0.8rem;
    color: #999;
  }

  /* Botón Ver Todo */
  .ver-todo-container {
    text-align: center;
    margin-top: 3.5rem;
  }
  .btn-ver-todo {
    display: inline-block;
    padding: 0.8rem 2rem;
    background-color: var(--color-primario);
    color: white;
    text-decoration: none;
    border-radius: 6px;
    font-weight: bold;
    transition: background 0.3s;
  }
  .btn-ver-todo:hover {
    background-color: var(--color-primario-hover);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .destacada-link {
      grid-template-columns: 1fr;
    }
    .destacada-img {
      height: 250px;
    }
    .destacada-content {
      padding: 1.5rem;
    }
  }
</style>
