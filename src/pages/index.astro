---
import Layout from "../layouts/Layout.astro";
import CmsInicioClient from "../components/cms/CmsInicioClient";

const isDevelopment =
  String(import.meta.env.ENVIRONMENT ?? import.meta.env.ENVIROMENT ?? "").toLowerCase() ===
  "development";
const clientSlug =
  String(import.meta.env.CLIENT_SLUG ?? import.meta.env.PUBLIC_CLIENT_SLUG ?? "").trim();
---

<Layout>
  <CmsInicioClient
    client:load
    clientSlug={clientSlug}
    isDevelopment={isDevelopment}
  />
</Layout>
