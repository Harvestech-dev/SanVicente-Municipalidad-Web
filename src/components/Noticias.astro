---
import data from "../data/noticias.json";

interface Noticia {
  id: number;
  titulo: string;
  resumen: string;
  fecha: string;
  categoria: string;
  imagen: string;
  destacada: boolean;
}

const {
  noticias = data.noticias as Noticia[],
  titulo = data.titulo,
  subtitulo = data.subtitulo,
  textoVerTodo = data.textoVerTodo,
  urlVerTodo = data.urlVerTodo,
} = Astro.props;

const noticiaDestacada = noticias.find((n: Noticia) => n.destacada);
const otrasNoticias = noticias.filter((n: Noticia) => !n.destacada).slice(0, 3);
---

<section class="news-section">
  <div class="container">
    <div class="section-header">
      <div class="header-text">
        <h2 class="title">{titulo}</h2>
        <p class="subtitle">{subtitulo}</p>
      </div>
      <a href={urlVerTodo} class="btn-outline desktop-only">
        {textoVerTodo}
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="m9 18 6-6-6-6"></path>
        </svg>
      </a>
    </div>

    <div class="news-grid">
      {
        noticiaDestacada && (
          <a href={`/noticias/${noticiaDestacada.id}`} class="featured-card">
            <div class="image-wrapper">
              <img src={noticiaDestacada.imagen} alt={noticiaDestacada.titulo} loading="lazy" />
              <span class="badge">{noticiaDestacada.categoria}</span>
            </div>
            <div class="content">
              <div class="meta">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect width="18" height="18" x="3" y="4" rx="2" ry="2" />
                  <path d="M16 2v4M8 2v4M3 10h18" />
                </svg>
                <span>{noticiaDestacada.fecha}</span>
              </div>
              <h3 class="news-title-large">{noticiaDestacada.titulo}</h3>
              <p class="news-excerpt">{noticiaDestacada.resumen}</p>
            </div>
          </a>
        )
      }

      <div class="news-list">
        {
          otrasNoticias.map((item: Noticia) => (
            <a href={`/noticias/${item.id}`} class="small-card">
              <div class="small-image">
                <img src={item.imagen} alt={item.titulo} loading="lazy" />
              </div>
              <div class="small-content">
                <span class="small-badge">{item.categoria}</span>
                <h4 class="small-title">{item.titulo}</h4>
                <div class="meta small">
                  <span>{item.fecha}</span>
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </div>

    <div class="mobile-only mt-8">
      <a href={urlVerTodo} class="btn-outline full-width">
        {textoVerTodo}
      </a>
    </div>
  </div>
</section>

<style>
  /* CONFIGURACIÓN BASE */
  .news-section * { box-sizing: border-box; }

  .news-section {
    padding: 5rem 1.5rem;
    background-color: #f1f5f9;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 3rem;
  }

  .title {
    font-size: clamp(1.8rem, 5vw, 2.25rem);
    font-weight: 800;
    color: var(--color-primario, #1e293b);
    margin-bottom: 0.5rem;
  }

  .subtitle { color: #64748b; font-size: 1.1rem; }

  /* GRID PRINCIPAL */
  .news-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 1024px) {
    .news-grid {
      grid-template-columns: 1.6fr 1fr;
      align-items: stretch;
    }
  }

  /* TARJETA DESTACADA */
  .featured-card {
    text-decoration: none;
    color: inherit;
    border-radius: 20px;
    overflow: hidden;
    background: white;
    display: flex;
    flex-direction: column;
    height: 100%;
    border: 1px solid rgba(0, 0, 0, 0.05);
    transition: transform 0.3s ease;
  }

  .featured-card:hover { transform: translateY(-4px); }

  .image-wrapper { position: relative; aspect-ratio: 16 / 9; }
  .image-wrapper img { width: 100%; height: 100%; object-fit: cover; }
  
  .badge {
    position: absolute;
    top: 1.25rem;
    left: 1.25rem;
    background: var(--color-primario, #2563eb);
    color: white;
    padding: 6px 14px;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 700;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
  }

  .featured-card .content { padding: 2rem; flex-grow: 1; }

  .news-title-large {
    font-size: clamp(1.4rem, 4vw, 1.85rem);
    font-weight: 800;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .news-excerpt {
    color: #475569;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* LISTA LATERAL SIMÉTRICA */
  .news-list {
    display: grid;
    grid-template-rows: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .small-card {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 1.25rem;
    text-decoration: none;
    color: inherit;
    padding: 1rem;
    background: white;
    border-radius: 18px;
    border: 1px solid rgba(0, 0, 0, 0.05);
    align-items: center;
    transition: all 0.3s ease;
  }

  .small-card:hover {
    border-color: var(--color-primario, #2563eb);
    transform: translateX(5px);
  }

  .small-image {
    width: 110px;
    height: 110px;
    border-radius: 12px;
    overflow: hidden;
  }

  .small-image img { width: 100%; height: 100%; object-fit: cover; }

  /* CATEGORÍAS SECUNDARIAS */
  .small-badge {
    display: inline-block;
    background: var(--color-primario, #2563eb);
    color: white;
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 0.7rem;
    font-weight: 700;
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .small-title {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 6px;
    line-height: 1.2;
    /* Evita que títulos largos rompan la simetría */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* UTILIDADES Y RESPONSIVE */
  .meta { display: flex; align-items: center; gap: 8px; color: #94a3b8; font-size: 0.85rem; }
  .meta.small { margin-top: auto; }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border: 2px solid var(--color-primario, #2563eb);
    border-radius: 12px;
    color: var(--color-primario, #2563eb);
    text-decoration: none;
    font-weight: 700;
    transition: all 0.3s ease;
  }

  .btn-outline:hover { background: var(--color-primario, #2563eb); color: white; }

  .desktop-only { display: none; }
  @media (min-width: 768px) { .desktop-only { display: inline-flex; } .mobile-only { display: none; } }
  
  .mt-8 { margin-top: 2rem; }
  .full-width { width: 100%; }

  @media (max-width: 480px) {
    .small-card { grid-template-columns: 80px 1fr; gap: 1rem; padding: 0.75rem; }
    .small-image { width: 80px; height: 80px; }
  }
</style>