---
import Layout from "../../../layouts/Layout.astro";
import LicitacionAttachment from "../../../components/LicitacionAttachment.astro";
import { fetchBiddings } from "../../../lib/api-licitaciones";
import type {
  BiddingItem,
  BiddingAttachment,
} from "../../../lib/api-licitaciones";

// El detalle usa solo los datos del listado (mismo fetch). No se usa el endpoint GET /biddings/:id.
export async function getStaticPaths() {
  const { items } = await fetchBiddings({ limit: 100 });
  return items.map((bidding) => {
    const id = bidding.id ?? (bidding as { _id?: string })._id ?? "";
    return { params: { id }, props: { bidding } };
  });
}

const { bidding } = Astro.props;
if (!bidding) {
  return Astro.redirect("/Transparencia/licitaciones");
}

function formatDate(iso: string | null | undefined): string {
  if (!iso) return "—";
  try {
    const d = new Date(iso);
    return d.toLocaleDateString("es-AR", {
      day: "numeric",
      month: "short",
      year: "numeric",
    });
  } catch {
    return String(iso);
  }
}

function formatBudget(amount: number | undefined, currency?: string): string {
  if (amount == null) return "—";
  const sym = currency === "ARS" ? "$" : (currency ?? "$");
  return `${sym} ${amount.toLocaleString("es-AR")}`;
}

function hasAttachmentUrl(a: BiddingAttachment): boolean {
  const url = (a.external_url ?? a.file_url)?.trim();
  return !!url;
}

const attachmentsWithUrl = bidding.attachments?.filter(hasAttachmentUrl) ?? [];

const statusLabels: Record<string, string> = {
  upcoming: "Próxima",
  open: "Abierta",
  in_evaluation: "En evaluación",
  closed: "Cerrada",
  awarded: "Adjudicada",
  deserted: "Desierta",
  cancelled: "Cancelada",
  suspended: "Suspendida",
};

const statusClasses: Record<string, string> = {
  upcoming: "status-upcoming",
  open: "status-open",
  in_evaluation: "status-evaluation",
  closed: "status-closed",
  awarded: "status-awarded",
  deserted: "status-deserted",
  cancelled: "status-cancelled",
  suspended: "status-suspended",
};

const hasWinner =
  bidding.winner &&
  (bidding.winner.company_name ?? bidding.winner.award_amount != null);
const procedureTypeLabel = bidding.procedure_type?.replace(/_/g, " ") ?? "";
---

<Layout title={`${bidding.title} | Licitaciones`}>
  <main class="licitaciones-container licitaciones-detail">
    <section class="hero-licitaciones">
      <div class="content-wrapper">
        <nav class="breadcrumb" aria-label="Miga de pan">
          <a href="/Transparencia/licitaciones">Licitaciones y Concursos</a>
 

        </nav>
        <d class="meta-row">
          {
            bidding.bidding_number && (
              <span class="id-tag">N° {bidding.bidding_number}</span>
            )
          }
          {
            bidding.expediente_number && (
              <span class="expediente-tag">
                Exp. {bidding.expediente_number}
              </span>
            )
          }
          {
            procedureTypeLabel && (
              <span class="type-badge">{procedureTypeLabel}</span>
            )
          }
                    {
                      bidding.effective_status && (
                        <span
                          class={`status-badge ${statusClasses[bidding.effective_status] ?? ""}`}
                        >
                          {statusLabels[bidding.effective_status] ??
                            bidding.effective_status}
                        </span>
                      )
                    }
                  
        </div>
        <h1>{bidding.title}</h1>
        {bidding.subtitle && <p class="hero-subtitle">{bidding.subtitle}</p>}
      </div>
    </section>

    <section class="detail-section">
      <div class="content-wrapper detail-layout">
        <div class="detail-main">
          {
            bidding.object_of_contract && (
              <section class="detail-block">
                <h2>Objeto del contrato</h2>
                <p class="object-text">{bidding.object_of_contract}</p>
              </section>
            )
          }

          <section class="detail-block data-block">
            <h2>Datos del proceso</h2>
            <dl class="data-grid detail-grid">
              <div class="data-item">
                <dt class="label">Publicación</dt>
                <dd class="value">
                  {formatDate(bidding.dates?.publication_date)}
                </dd>
              </div>
              <div class="data-item">
                <dt class="label">Inicio recepción ofertas</dt>
                <dd class="value">
                  {formatDate(bidding.dates?.bidding_start_date)}
                </dd>
              </div>
              <div class="data-item">
                <dt class="label">Cierre recepción ofertas</dt>
                <dd class="value">
                  {formatDate(bidding.dates?.bidding_end_date)}
                </dd>
              </div>
              <div class="data-item">
                <dt class="label">Fecha de apertura</dt>
                <dd class="value">{formatDate(bidding.dates?.opening_date)}</dd>
              </div>
              <div class="data-item">
                <dt class="label">Adjudicación</dt>
                <dd class="value">{formatDate(bidding.dates?.award_date)}</dd>
              </div>
              {
                bidding.area && (
                  <div class="data-item">
                    <dt class="label">Área</dt>
                    <dd class="value">{bidding.area}</dd>
                  </div>
                )
              }
              {
                bidding.location && (
                  <div class="data-item">
                    <dt class="label">Ubicación</dt>
                    <dd class="value">{bidding.location}</dd>
                  </div>
                )
              }
              {
                bidding.opening_location && (
                  <div class="data-item data-item-full">
                    <dt class="label">Lugar de apertura</dt>
                    <dd class="value">{bidding.opening_location}</dd>
                  </div>
                )
              }
              {
                bidding.consultation_contact && (
                  <div class="data-item data-item-full">
                    <dt class="label">Consultas</dt>
                    <dd class="value">
                      {bidding.consultation_contact.includes("@") ||
                      bidding.consultation_contact.includes(".") ? (
                        <a
                          href={`mailto:${bidding.consultation_contact.trim()}`}
                        >
                          {bidding.consultation_contact}
                        </a>
                      ) : (
                        bidding.consultation_contact
                      )}
                    </dd>
                  </div>
                )
              }
            </dl>
          </section>

          {
            hasWinner && bidding.winner && (
              <section class="detail-block winner-block">
                <h2>Adjudicación</h2>
                <dl class="winner-grid">
                  {bidding.winner.company_name && (
                    <div class="data-item">
                      <dt class="label">Empresa adjudicada</dt>
                      <dd class="value">{bidding.winner.company_name}</dd>
                    </div>
                  )}
                  {bidding.winner.cuit && (
                    <div class="data-item">
                      <dt class="label">CUIT</dt>
                      <dd class="value">{bidding.winner.cuit}</dd>
                    </div>
                  )}
                  {bidding.winner.award_amount != null && (
                    <div class="data-item">
                      <dt class="label">Monto adjudicado</dt>
                      <dd class="value budget-value">
                        {formatBudget(
                          bidding.winner.award_amount,
                          bidding.currency,
                        )}
                      </dd>
                    </div>
                  )}
                </dl>
              </section>
            )
          }

          <div class="detail-footer">
            <a href="/Transparencia/licitaciones" class="btn-back">
              ← Volver a Licitaciones y Concursos
            </a>
          </div>
        </div>

        <aside class="detail-sidebar">
          <div class="sidebar-card budget-box">
            <span class="budget-label">Presupuesto oficial</span>
            <span class="budget-value"
              >{formatBudget(bidding.budget_official, bidding.currency)}</span
            >
          </div>

          <div class="sidebar-card attachments-card">
            <h3>Documentos</h3>
            <div class="button-group">
              {
                attachmentsWithUrl.length === 0 ? (
                  <p class="no-docs">No hay documentos cargados.</p>
                ) : (
                  attachmentsWithUrl.map((att) => (
                    <LicitacionAttachment
                      attachment={att}
                      class="btn-outline-sm"
                    />
                  ))
                )
              }
            </div>
          </div>
        </aside>
      </div>
    </section>
  </main>
</Layout>

<style>
  .licitaciones-detail .licitaciones-container {
    min-height: 100vh;
    background-color: var(--color-fondo-claro);
  }
  .content-wrapper {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .hero-licitaciones {
    background-color: var(--color-primario);
    color: white;
    padding: 3rem 0 4rem;
    text-align: center;
  }
  .hero-licitaciones .breadcrumb {
    font-size: 0.85rem;
    opacity: 0.95;
    margin-bottom: 1rem;
  }
  .hero-licitaciones .breadcrumb a {
    color: white;
    text-decoration: none;
    font-weight: 600;
  }
  .hero-licitaciones .breadcrumb a:hover {
    text-decoration: underline;
  }
  .hero-licitaciones .sep {
    margin: 0 0.5rem;
    opacity: 0.8;
  }
  .hero-licitaciones .current {
    font-weight: 600;
  }
  .hero-licitaciones .meta-row {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    align-items: center;
  }
  .hero-licitaciones .id-tag,
  .hero-licitaciones .expediente-tag {
    font-family: monospace;
    font-weight: bold;
    font-size: 0.9rem;
    opacity: 0.95;
  }
  .hero-licitaciones .status-badge,
  .hero-licitaciones .type-badge {
    padding: 0.25rem 0.75rem;
    border-radius: 99px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
  }
  .hero-licitaciones .type-badge {
    background: rgba(255, 255, 255, 0.25);
    color: white;
  }
  .status-upcoming {
    background: #dbeafe;
    color: #1d4ed8;
  }
  .status-open {
    background: #dcfce7;
    color: #15803d;
  }
  .status-evaluation {
    background: #ffedd5;
    color: #c2410c;
  }
  .status-closed {
    background: #f1f5f9;
    color: #475569;
  }
  .status-awarded {
    background: #e0e7ff;
    color: #3730a3;
  }
  .status-deserted {
    background: #fef3c7;
    color: #92400e;
  }
  .status-cancelled,
  .status-suspended {
    background: #fee2e2;
    color: #b91c1c;
  }

  .hero-licitaciones h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    margin-bottom: 0.5rem;
    line-height: 1.2;
  }
  .hero-subtitle {
    font-size: 1.1rem;
    opacity: 0.9;
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.5;
  }

  .detail-section {
    padding: 3rem 0 4rem;
  }
  .detail-layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 2.5rem;
    align-items: start;
  }
  .detail-main {
    min-width: 0;
  }
  .detail-sidebar {
    position: sticky;
    /* Anclado debajo de la navbar (~70px) + margen */
    top: calc(72px + 0.75rem);
  }

  .detail-block {
    background: white;
    border-radius: 12px;
    border: 1px solid #e2e8f0;
    padding: 2rem;
    margin-bottom: 1.5rem;
  }
  .detail-block h2 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-texto);
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid #e2e8f0;
  }
  .object-text {
    font-size: 1rem;
    line-height: 1.7;
    color: #475569;
    margin: 0;
  }
  .detail-grid,
  .winner-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem 2rem;
    margin: 0;
  }
  .detail-grid .data-item-full,
  .winner-grid .data-item-full {
    grid-column: 1 / -1;
  }
  .data-item .label,
  .data-item dt.label {
    font-size: 0.75rem;
    color: #94a3b8;
    font-weight: 600;
    text-transform: uppercase;
    margin-bottom: 0.25rem;
  }
  .data-item .value,
  .data-item dd.value {
    font-size: 0.95rem;
    font-weight: 500;
    color: #334155;
    margin: 0;
  }
  .data-item .value a {
    color: var(--color-primario);
    text-decoration: none;
  }
  .data-item .value a:hover {
    text-decoration: underline;
  }
  .budget-value {
    font-weight: 700;
    color: var(--color-primario);
  }

  .sidebar-card {
    background: white;
    border-radius: 12px;
    border: 1px solid #e2e8f0;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .sidebar-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-texto);
    margin-bottom: 1rem;
  }
  .budget-label {
    display: block;
    font-size: 0.8rem;
    color: #94a3b8;
  }
  .budget-value {
    display: block;
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-primario);
    margin-top: 0.25rem;
  }
  .button-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .btn-primary-sm,
  .btn-outline-sm {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.6rem;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    transition: 0.2s;
  }
  .btn-primary-sm {
    background: var(--color-primario);
    color: white;
  }
  .btn-primary-sm:hover {
    background: var(--color-primario-hover);
  }
  .btn-outline-sm {
    border: 1.5px solid var(--color-primario);
    color: var(--color-primario);
  }
  .btn-outline-sm:hover {
    background: var(--color-primario);
    color: white;
  }
  .no-docs {
    font-size: 0.9rem;
    color: #94a3b8;
    margin: 0;
  }

  .detail-footer {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid #e2e8f0;
  }
  .btn-back {
    color: var(--color-primario);
    text-decoration: none;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    transition: transform 0.2s;
  }
  .btn-back:hover {
    transform: translateX(-4px);
  }

  @media (max-width: 900px) {
    .detail-layout {
      grid-template-columns: 1fr;
    }
    .detail-sidebar {
      position: static;
      order: -1;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
    .detail-sidebar .attachments-card {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 600px) {
    .detail-sidebar {
      grid-template-columns: 1fr;
    }
    .hero-licitaciones h1 {
      font-size: 1.75rem;
    }
  }
</style>
