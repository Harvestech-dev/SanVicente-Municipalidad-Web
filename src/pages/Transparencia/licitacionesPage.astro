---
import Layout from "../../layouts/Layout.astro";
import dataLicitaciones from "../../data/Transparencia/licitaciones.json";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const { lista_licitaciones: licitaciones, txt_titulo: titulo, txt_descripcion: descripcion } = dataLicitaciones;
---

<Layout>
  <Header />
  <main class="licitaciones-container">
    <section class="hero-licitaciones">
      <div class="content-wrapper">
        <div class="icon-header">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="32"
            height="32"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path
              d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"
            ></path><polyline points="14 2 14 8 20 8"></polyline><line
              x1="16"
              y1="13"
              x2="8"
              y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><line
              x1="10"
              y1="9"
              x2="8"
              y2="9"></line></svg
          >
        </div>
        <h1>{titulo}</h1>
        <p>{descripcion}</p>
      </div>
    </section>

    <section class="list-section">
      <div class="content-wrapper grid-gap">
        {
          licitaciones.map((licitacion) => (
            <article class="licitacion-card">
              <div class="card-main-info">
                <div class="meta-row">
                  <span class="id-tag">{licitacion._id}</span>
                  <span class="type-badge">{licitacion.txt_tipo}</span>
                </div>
                <h3>{licitacion.txt_titulo}</h3>
                <p class="card-desc">{licitacion.txt_descripcion}</p>

                <div class="data-grid">
                  <div class="data-item">
                    <span class="label">Apertura:</span>
                    <span class="value">{licitacion.txt_fecha_apertura}</span>
                  </div>
                  <div class="data-item">
                    <span class="label">Cierre:</span>
                    <span class="value">{licitacion.txt_fecha_cierre}</span>
                  </div>
                  <div class="data-item">
                    <span class="label">Área:</span>
                    <span class="value">{licitacion.txt_area}</span>
                  </div>
                </div>
              </div>

              <div class="card-side-info">
                <div class="budget-box">
                  <span class="budget-label">Presupuesto estimado</span>
                  <span class="budget-value">{licitacion.txt_presupuesto}</span>
                </div>
                <div class="button-group">
                  <a
                    href={licitacion.img_principal}
                    target="_blank"
                    class="btn-outline-sm"
                  >
                    Ver imagen <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                  </a>
                  <a
                    href={licitacion.link_pliego}
                    download
                    class="btn-primary-sm"
                  >
                    Ver pliego <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                  </a>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <!-- sección hecha por si hay que agregar info para quienes quieran licitar -->
     <!--
    <section class="info-footer-section">
      <div class="content-wrapper narrow-content">
        <h2>¿Querés participar de una licitación?</h2>
        <p>
          Para participar en los procesos licitatorios, debés estar inscripto en
          el Registro de Proveedores de la Municipalidad.
        </p>
        <div class="cta-group">
          <a href="/proveedores" class="btn-primary">Registro de Proveedores</a>
          <a href="mailto:compras@muni.gob.ar" class="btn-outline"
            >Enviar consulta</a
          >
        </div>
      </div>
    </section>
    -->
  </main>
  <Footer />
</Layout>

<style>
  /* Layout Base */
  .licitaciones-container {
    min-height: 100vh;
    background-color: var(--color-fondo-claro);
  }
  .content-wrapper {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .grid-gap {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Hero */
  .hero-licitaciones {
    background-color: var(--color-primario);
    color: white;
    padding: 4rem 0;
    text-align: center;
  }
  .icon-header {
    background: rgba(255, 255, 255, 0.2);
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
  }
  .hero-licitaciones h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }
  .hero-licitaciones p {
    opacity: 0.9;
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* Cards */
  .list-section {
    padding: 3rem 0;
  }
  .licitacion-card {
    background: white;
    border-radius: 12px;
    border: 1px solid #e2e8f0;
    padding: 2rem;
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    transition: transform 0.2s;
  }
  .licitacion-card:hover {
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
  }

  .meta-row {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1rem;
    align-items: center;
  }
  .id-tag {
    font-family: monospace;
    color: var(--color-primario);
    font-weight: bold;
    font-size: 0.9rem;
  }
  .type-badge {
    background: #f1f5f9;
    color: #475569;
    padding: 0.25rem 0.75rem;
    border-radius: 99px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    border: 1px solid #e2e8f0;
  }

  .licitacion-card h3 {
    font-size: 1.4rem;
    margin-bottom: 0.75rem;
    color: var(--color-texto);
  }
  .card-desc {
    color: #64748b;
    font-size: 0.95rem;
    line-height: 1.5;
    margin-bottom: 1.5rem;
  }

  .data-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
  }
  .data-item {
    display: flex;
    flex-direction: column;
  }
  .data-item .label {
    font-size: 0.75rem;
    color: #94a3b8;
    font-weight: 600;
    text-transform: uppercase;
  }
  .data-item .value {
    font-size: 0.9rem;
    font-weight: 500;
    color: #334155;
  }

  /* Card Side (Presupuesto y Botones) */
  .card-side-info {
    min-width: 220px;
    text-align: right;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .budget-label {
    display: block;
    font-size: 0.8rem;
    color: #94a3b8;
  }
  .budget-value {
    display: block;
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-primario);
    margin-top: 0.25rem;
  }

  .button-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 1.5rem;
  }
  .btn-primary-sm,
  .btn-outline-sm {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.6rem;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    transition: 0.2s;
  }
  .btn-primary-sm {
    background: var(--color-primario);
    color: white;
  }
  .btn-primary-sm:hover {
    background: var(--color-primario-hover);
  }
  .btn-outline-sm {
    border: 1.5px solid var(--color-primario);
    color: var(--color-primario);
  }
  .btn-outline-sm:hover {
    background: var(--color-primario);
    color: white;
  }

  /* Footer CTA */
  .info-footer-section {
    padding: 4rem 0;
    background: white;
    text-align: center;
    border-top: 1px solid #e2e8f0;
  }
  .narrow-content {
    max-width: 600px;
  }
  .info-footer-section h2 {
    margin-bottom: 1rem;
    font-size: 1.8rem;
  }
  .info-footer-section p {
    color: #64748b;
    margin-bottom: 2rem;
  }
  .cta-group {
    display: flex;
    gap: 1rem;
    justify-content: center;
  }
  .btn-primary {
    background: var(--color-primario);
    color: white;
    padding: 0.8rem 1.5rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
  }
  .btn-outline {
    border: 1.5px solid #cbd5e1;
    color: #475569;
    padding: 0.8rem 1.5rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .licitacion-card {
      flex-direction: column;
      padding: 1.5rem;
    }
    .card-side-info {
      text-align: left;
      min-width: auto;
    }
    .button-group {
      flex-direction: row;
    }
    .button-group a {
      flex: 1;
    }
    .hero-licitaciones h1 {
      font-size: 1.8rem;
    }
    .cta-group {
      flex-direction: column;
    }
  }
</style>
