---
import data from "../data/programas.json";
import sitioData from "../data/sitio.json";

interface Programa {
  _orden?: number;
  txt_nombre: string;
  txt_descripcion: string;
  link_url: string;
  _sigla?: string;
  img_logo?: string;
  img_fondo?: string;
}

const { data: cmsData, titulo: propTitulo, subtitulo: propSubtitulo } = Astro.props;
const source = (cmsData as Record<string, unknown>) ?? data;
const programasRaw = (source.lista_programas ?? data.lista_programas).slice(0, 6);
const programas = (programasRaw as unknown) as Programa[];
const titulo = (propTitulo ?? source.txt_titulo ?? data.txt_titulo) as string;
const subtitulo = (propSubtitulo ?? source.txt_subtitulo ?? data.txt_subtitulo) as string;
const tema = sitioData._estilo;
---

<section class="featured-programs">
  <div class="container">
    <div class="header">
      <h2 class="title">{titulo}</h2>
      <p class="subtitle">{subtitulo}</p>
    </div>

    <div class="programs-grid">
      {
        programas.map((prog: Programa) => (
          <a href={prog.link_url} class="program-card">
            <div class="logo-box">
              {prog.img_logo ? (
                <img src={prog.img_logo} alt={prog.txt_nombre} />
              ) : (
                <span class="sigla">{prog._sigla}</span>
              )}
            </div>

            <div class="content">
              <h3 class="program-name">{prog.txt_nombre}</h3>
              <p class="program-desc">{prog.txt_descripcion}</p>
            </div>
          </a>
        ))
      }
    </div>

    <div class="action-container">
      <a href="/programasPage" class="btn-ver-todos">
        Ver todos los programas
      </a>
    </div>
  </div>
</section>

<style
  define:vars={{
    primario: tema.primario,
    texto: tema.texto,
    fondoClaro: "#f1f5f9",
  }}
>
  .featured-programs {
    padding: 5rem 1.5rem;
    background-color: var(--fondoClaro);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .title {
    font-size: clamp(1.75rem, 5vw, 2.25rem);
    font-weight: 800;
    color: var(--primario);
    margin-bottom: 0.75rem;
  }

  .subtitle {
    font-size: 1.1rem;
    color: #64748b;
    max-width: 600px;
    margin: 0 auto;
  }

  .programs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  .program-card {
    background: white;
    border-radius: 16px;
    padding: 1.25rem;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    border: 1px solid rgba(0, 0, 0, 0.05);
    transition: all 0.3s ease;
  }

  .program-card:hover {
    transform: translateY(-5px);
    border-color: var(--primario);
    box-shadow: 0 10px 20px rgba(0,0,0,0.05);
  }

  /* logo box */
  .logo-box {
    width: 60px;
    height: 60px;
    border-radius: 12px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #374151;
    color: #ffffff;
    transition: transform 0.3s ease;
  }

  .program-card:hover .logo-box {
    transform: scale(1.05);
  }

  .sigla {
    font-size: 1.2rem;
    font-weight: 800;
  }

  .logo-box img {
    width: 60%;
    height: 60%;
    object-fit: contain;
    filter: brightness(0) invert(1);
  }

  .content {
    display: flex;
    flex-direction: column;
  }

  .program-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--texto);
    margin: 0;
  }

  .program-desc {
    font-size: 0.85rem;
    color: #64748b;
    margin-top: 0.25rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /*  BOTÓN VER TODOS */
  .action-container {
    margin-top: 3.5rem;
    display: flex;
    justify-content: center;
  }

  .btn-ver-todos {
    background-color: var(--primario);
    color: white;
    padding: 0.75rem 2rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: background-color 0.3s ease;
  }

  .btn-ver-todos:hover {
    background-color: #1f2937;
  }
</style>