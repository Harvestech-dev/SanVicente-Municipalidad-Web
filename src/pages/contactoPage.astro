---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SocialIcon } from "../components/SocialIcon";
import data from "./../data/contactoPage/contacto-page.json";
const {
  hero,
  bannerDigital,
  lista_oficinas: edificios,
  telefonosUtiles,
} = data;

interface Contacto {
  icon_contacto?: string;
  txt_label?: string;
  link_destino?: string;
  txt_valor?: string;
}

interface Dependencia {
  _id?: string;
  txt_titulo?: string;
  _orden?: number;
  _icon?: string;
  lista_contactos?: Contacto[];
  lista_dependencias?: Dependencia[];
}

interface Edificio {
  txt_titulo?: string;
  txt_subtitulo?: string;
  _id?: string;
  _orden?: number;
  _boolean_isDefault?: boolean;
  _icon?: string;
  lista_contactos?: Contacto[];
  lista_dependencias?: Dependencia[];
}

interface SearchResultItem {
  titulo: string;
  label: string;
  valor: string;
  link: string;
  icon: string;
}

function buildSearchIndex(
  edificios: Edificio[],
  telefonosUtiles: { lista_telefonos?: Array<{ txt_nombre?: string; _icon?: string; lista_contactos?: Contacto[] }> }
): SearchResultItem[] {
  const items: SearchResultItem[] = [];
  const addContact = (titulo: string, c: Contacto, icon: string) => {
    items.push({
      titulo,
      label: c.txt_label ?? "",
      valor: c.txt_valor ?? "",
      link: c.link_destino ?? "",
      icon: c.icon_contacto ?? icon,
    });
  };
  (edificios ?? []).forEach((e) => {
    const baseTitulo = e.txt_titulo ?? "";
    (e.lista_contactos ?? []).forEach((c) => addContact(baseTitulo, c, e._icon ?? "FaLink"));
    (e.lista_dependencias ?? []).forEach((sec) => {
      const tituloSec = baseTitulo ? `${baseTitulo} › ${sec.txt_titulo ?? ""}` : (sec.txt_titulo ?? "");
      (sec.lista_contactos ?? []).forEach((c) => addContact(tituloSec, c, sec._icon ?? "FaLink"));
      (sec.lista_dependencias ?? []).forEach((sub) => {
        const tituloSub = tituloSec ? `${tituloSec} › ${sub.txt_titulo ?? ""}` : (sub.txt_titulo ?? "");
        (sub.lista_contactos ?? []).forEach((c) => addContact(tituloSub, c, sub._icon ?? "FaLink"));
      });
    });
  });
  (telefonosUtiles.lista_telefonos ?? []).forEach((tel) => {
    const titulo = tel.txt_nombre ?? "";
    (tel.lista_contactos ?? []).forEach((c) => addContact(titulo, c, tel._icon ?? "FaPhone"));
  });
  return items;
}

const searchIndex = buildSearchIndex(edificios as Edificio[], telefonosUtiles);
---

<Layout title={`${hero.txt_titulo} | Municipalidad de San Vicente (Santa Fe)`}>
  <Header />
  <main class="contact-page">
    <section class="hero-contact">
      <div class="container">
        <h1>{hero.txt_titulo}</h1>
        <p>{hero.txt_descripcion}</p>
      </div>
    </section>

    <div id="vecino-digital-tip" class="vecino-digital-floating" role="complementary" aria-label="Sugerencia Vecino Digital">
      <button type="button" class="vecino-digital-close" aria-label="Cerrar sugerencia">&times;</button>
      <div class="digital-card digital-card-floating">
        <div class="digital-content">
          <div class="digital-badge">Contactanos</div>
          <h3>{bannerDigital.txt_titulo}</h3>
          <p>{bannerDigital.txt_subtitulo}</p>
        </div>
        <a
          href={bannerDigital.link_url}
          target="_blank"
          class="btn-digital-new"
        >
          <span>{bannerDigital.txt_boton}</span>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </div>
    </div>

    <section class="filters-bar">
      <div class="container filters-flex">
        <div class="search-wrapper">
          <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.35-4.35"/>
          </svg>
          <input
            type="search"
            id="contact-search"
            class="search-input"
            placeholder="Buscar contactos..."
            autocomplete="off"
          />
        </div>
      </div>
      <div class="container">
        <div id="search-results" class="search-results" aria-live="polite" hidden></div>
      </div>
    </section>

    <section class="section-offices">
      <div class="container">
        <h2 class="section-title">Organización y Contacto</h2>
        <p class="section-desc section-desc-centered">
          Edificios, secretarías y áreas de la Municipalidad.
        </p>
        <div class="edificios-list">
          {
            (edificios as Edificio[])
              .sort((a, b) => (a._orden ?? 0) - (b._orden ?? 0))
              .map((edificio) => (
                <article
                  class={`edificio-card ${edificio._boolean_isDefault ? "edificio-default" : ""}`}
                >
                  <header class="edificio-header">
                    <div class="edificio-icon">
                      <SocialIcon
                        iconName={edificio._icon ?? "FaBuilding"}
                        size={24}
                      />
                    </div>
                    <div class="edificio-titles">
                      <h3 class="edificio-title">{edificio.txt_titulo}</h3>
                      {edificio.txt_subtitulo && (
                        <p class="edificio-subtitle">
                          {edificio.txt_subtitulo}
                        </p>
                      )}
                    </div>
                  </header>
                  <div class="edificio-contactos">
                    {(edificio.lista_contactos ?? []).map((c) => (
                      <div class="contacto-item">
                        <span class="contact-icon">
                          <SocialIcon
                            iconName={c.icon_contacto ?? "FaLink"}
                            size={16}
                          />
                        </span>
                        {c.link_destino ? (
                          <a
                            href={c.link_destino}
                            target={
                              c.link_destino.startsWith("http")
                                ? "_blank"
                                : undefined
                            }
                            rel={
                              c.link_destino.startsWith("http")
                                ? "noopener noreferrer"
                                : undefined
                            }
                            class="contact-link"
                          >
                            {c.txt_valor ?? c.link_destino}
                          </a>
                        ) : (
                          <span>{c.txt_valor ?? ""}</span>
                        )}
                      </div>
                    ))}
                  </div>
                  {(edificio.lista_dependencias ?? []).length > 0 && (
                    <div class="dependencias-wrap">
                      <details class="nivel-details secretarias-details">
                        <summary class="nivel-label nivel-label-toggle">
                          <span class="chevron" aria-hidden="true" />
                          Áreas
                        </summary>
                        <ul class="secretarias-list">
                          {(edificio.lista_dependencias ?? [])
                            .sort((a, b) => (a._orden ?? 0) - (b._orden ?? 0))
                            .map((sec) => (
                              <li class="secretaria-item">
                                <div class="secretaria-header">
                                  <SocialIcon
                                    iconName={sec._icon ?? "FaBuilding"}
                                    size={18}
                                  />
                                  <h4 class="secretaria-title">
                                    {sec.txt_titulo}
                                  </h4>
                                </div>
                                <div class="secretaria-content">
                                  <div class="secretaria-contactos">
                                    {(sec.lista_contactos ?? []).map((c) => (
                                      <div class="contacto-item contacto-item-sm">
                                        <span class="contact-icon">
                                          <SocialIcon
                                            iconName={
                                              c.icon_contacto ?? "FaLink"
                                            }
                                            size={14}
                                          />
                                        </span>
                                        {c.link_destino ? (
                                          <a
                                            href={c.link_destino}
                                            target={
                                              c.link_destino.startsWith("http")
                                                ? "_blank"
                                                : undefined
                                            }
                                            rel={
                                              c.link_destino.startsWith("http")
                                                ? "noopener noreferrer"
                                                : undefined
                                            }
                                            class="contact-link"
                                          >
                                            {c.txt_valor ?? c.link_destino}
                                          </a>
                                        ) : (
                                          <span>{c.txt_valor ?? ""}</span>
                                        )}
                                      </div>
                                    ))}
                                  </div>
                                  {(sec.lista_dependencias ?? []).length >
                                    0 && (
                                    <div class="subsecretarias-wrap">
                                      <details class="nivel-details subsecretarias-details">
                                        <summary class="nivel-label nivel-label-sm nivel-label-toggle">
                                          <span
                                            class="chevron chevron-sm"
                                            aria-hidden="true"
                                          />
                                          Subsecretarías
                                        </summary>
                                        <ul class="subsecretarias-list">
                                          {(sec.lista_dependencias ?? [])
                                            .sort(
                                              (a, b) =>
                                                (a._orden ?? 0) -
                                                (b._orden ?? 0),
                                            )
                                            .map((sub) => (
                                              <li class="subsecretaria-item">
                                                <div class="subsecretaria-header">
                                                  <SocialIcon
                                                    iconName={
                                                      sub._icon ?? "FaLink"
                                                    }
                                                    size={16}
                                                  />
                                                  <h5 class="subsecretaria-title">
                                                    {sub.txt_titulo}
                                                  </h5>
                                                </div>
                                                <div class="subsecretaria-contactos">
                                                  {(
                                                    sub.lista_contactos ?? []
                                                  ).map((c) => (
                                                    <div class="contacto-item contacto-item-xs">
                                                      <span class="contact-icon">
                                                        <SocialIcon
                                                          iconName={
                                                            c.icon_contacto ??
                                                            "FaLink"
                                                          }
                                                          size={12}
                                                        />
                                                      </span>
                                                      {c.link_destino ? (
                                                        <a
                                                          href={c.link_destino}
                                                          target={
                                                            c.link_destino.startsWith(
                                                              "http",
                                                            )
                                                              ? "_blank"
                                                              : undefined
                                                          }
                                                          rel={
                                                            c.link_destino.startsWith(
                                                              "http",
                                                            )
                                                              ? "noopener noreferrer"
                                                              : undefined
                                                          }
                                                          class="contact-link"
                                                        >
                                                          {c.txt_valor ??
                                                            c.link_destino}
                                                        </a>
                                                      ) : (
                                                        <span>
                                                          {c.txt_valor ?? ""}
                                                        </span>
                                                      )}
                                                    </div>
                                                  ))}
                                                </div>
                                              </li>
                                            ))}
                                        </ul>
                                      </details>
                                    </div>
                                  )}
                                </div>
                              </li>
                            ))}
                        </ul>
                      </details>
                    </div>
                  )}
                </article>
              ))
          }
        </div>
      </div>
    </section>

    <section class="section-phones">
      <div class="container">
        <h2 class="section-subtitle section-subtitle-centered">{telefonosUtiles.txt_titulo ?? "Teléfonos útiles"}</h2>
        <p class="section-desc section-desc-centered">{telefonosUtiles.txt_subtitulo ?? "Contactos importantes para situaciones urgentes"}</p>
        <div class="phones-grid">
          {(telefonosUtiles.lista_telefonos ?? [])
            .sort((a, b) => (a._orden ?? 0) - (b._orden ?? 0))
            .map((tel) => {
              const contactos = tel.lista_contactos ?? [];
              return (
                <article class="phone-card">
                  <div class="phone-card-icon">
                    <SocialIcon
                      iconName={tel._icon ?? "FaPhone"}
                      size={24}
                    />
                  </div>
                  <div class="phone-card-content">
                    <h3 class="phone-card-title">{tel.txt_nombre}</h3>
                    <div class="phone-contacts">
                      {contactos.map((c) => (
                        <div class="phone-contact-item">
                          <div class="phone-contact-content">
                            <span class="phone-contact-label">{c.txt_label ?? ""}</span>
                            {c.link_destino ? (
                              <a
                                href={c.link_destino}
                                target={c.link_destino.startsWith("http") ? "_blank" : undefined}
                                rel={c.link_destino.startsWith("http") ? "noopener noreferrer" : undefined}
                                class="phone-contact-link"
                              >
                                <span class="phone-contact-icon">
                                  <SocialIcon
                                    iconName={c.icon_contacto ?? tel._icon ?? "FaPhone"}
                                    size={12}
                                  />
                                </span>
                                <span>{c.txt_valor ?? ""}</span>
                              </a>
                            ) : (
                              <span class="phone-contact-value">
                                <span class="phone-contact-icon">
                                  <SocialIcon
                                    iconName={c.icon_contacto ?? tel._icon ?? "FaPhone"}
                                    size={12}
                                  />
                                </span>
                                <span>{c.txt_valor ?? ""}</span>
                              </span>
                            )}
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                </article>
              );
            })}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script define:vars={{ searchIndex }}>
  const input = document.getElementById("contact-search");
  const resultsEl = document.getElementById("search-results");

  function normalize(str) {
    return (str || "")
      .toLowerCase()
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "")
      .trim();
  }

  function search(query) {
    const q = normalize(query);
    if (!q || q.length < 2) return [];
    return searchIndex.filter(
      (item) =>
        normalize(item.titulo).includes(q) ||
        normalize(item.label).includes(q) ||
        normalize(item.valor).includes(q)
    );
  }

  const iconSvg = {
    FaPhone: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>',
    FaEnvelope: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>',
    FaWhatsapp: '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>',
    FaMapMarkerAlt: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>',
    FaClock: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
    FaLink: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>',
  };
  function getIconSvg(icon) {
    return iconSvg[icon] || iconSvg.FaLink;
  }
  function renderResult(item) {
    const link = item.link && item.link.trim() !== "";
    const href = link ? item.link : "#";
    const target = link && item.link.startsWith("http") ? "_blank" : "";
    const rel = link && item.link.startsWith("http") ? "noopener noreferrer" : "";
    const icon = getIconSvg(item.icon);
    const content = link
      ? `<a href="${href}" ${target ? `target="${target}"` : ""} ${rel ? `rel="${rel}"` : ""} class="search-result-link">${escapeHtml(item.valor)}</a>`
      : `<span class="search-result-value">${escapeHtml(item.valor)}</span>`;
    return `
      <div class="search-result-item">
        <h4 class="search-result-titulo">${escapeHtml(item.titulo)}</h4>
        <div class="search-result-contact">
          <span class="search-result-icon">${icon}</span>
          <div class="search-result-content">
            ${item.label ? `<span class="search-result-label">${escapeHtml(item.label)}</span>` : ""}
            ${content}
          </div>
        </div>
      </div>
    `;
  }

  function escapeHtml(s) {
    const div = document.createElement("div");
    div.textContent = s;
    return div.innerHTML;
  }

  input?.addEventListener("input", () => {
    const query = input.value.trim();
    if (!resultsEl) return;
    if (query.length < 2) {
      resultsEl.hidden = true;
      resultsEl.innerHTML = "";
      return;
    }
    const hits = search(query);
    if (hits.length === 0) {
      resultsEl.hidden = false;
      resultsEl.innerHTML = '<p class="search-no-results">No se encontraron resultados.</p>';
      return;
    }
    resultsEl.hidden = false;
    resultsEl.innerHTML = hits.map(renderResult).join("");
  });

  // --- Card flotante Vecino Digital ---
  const STORAGE_KEY = "vecino-digital-tip-closed";
  const tipEl = document.getElementById("vecino-digital-tip");
  const closeBtn = tipEl?.querySelector(".vecino-digital-close");

  if (tipEl && closeBtn) {
    if (typeof localStorage !== "undefined" && localStorage.getItem(STORAGE_KEY) === "true") {
      tipEl.classList.add("hidden");
    }
    closeBtn.addEventListener("click", () => {
      tipEl.classList.add("hidden");
      try {
        localStorage.setItem(STORAGE_KEY, "true");
      } catch (_) {}
    });
  }
</script>

<style>
  /* --- CONFIGURACIÓN BASE --- */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* --- HERO --- */
  .hero-contact {
    background-color: var(--color-primario);
    color: white;
    padding: 4rem 0;
    text-align: center;
  }
  .hero-contact h1 {
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    font-weight: 800;
    margin-bottom: 1rem;
  }
  .hero-contact p {
    font-size: 1.2rem;
    opacity: 0.9;
    max-width: 600px;
    margin: 0 auto;
  }

  /* --- CARD FLOTANTE VECINO DIGITAL --- */
  .vecino-digital-floating {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 1000;
    max-width: 340px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }
  .vecino-digital-floating.hidden {
    transform: translateY(120%);
    opacity: 0;
    pointer-events: none;
  }
  .vecino-digital-close {
    position: absolute;
    top: -0.5rem;
    right: -0.5rem;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: none;
    background: #64748b;
    color: white;
    font-size: 1.25rem;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
    transition: background 0.2s;
  }
  .vecino-digital-close:hover {
    background: #475569;
  }
  .digital-card-floating {
    background: white;
    padding: 1.5rem;
    border-radius: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.15);
    border: 1px solid rgba(0, 0, 0, 0.08);
  }
  .digital-card-floating .digital-content h3 {
    font-size: 1.25rem;
  }
  .digital-card-floating .digital-content p {
    font-size: 0.95rem;
  }
  .digital-card-floating .btn-digital-new {
    width: 100%;
    justify-content: center;
    padding: 0.75rem 1.25rem;
    font-size: 0.95rem;
  }
  @media (max-width: 480px) {
    .vecino-digital-floating {
      right: 1rem;
      left: 1rem;
      max-width: none;
    }
  }
  .digital-badge {
    background: var(--color-primario-claro, #e0f2fe);
    color: var(--color-primario);
    padding: 0.4rem 1rem;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 700;
    display: inline-block;
    margin-bottom: 1rem;
  }
  .digital-content h3 {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--color-texto);
    margin-bottom: 0.5rem;
  }
  .digital-content p {
    color: #64748b;
    font-size: 1.1rem;
  }

  .btn-digital-new {
    background: var(--color-primario);
    color: white;
    padding: 1rem 2rem;
    border-radius: 1rem;
    text-decoration: none;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 1rem;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .btn-digital-new:hover {
    transform: scale(1.05);
    filter: brightness(1.1);
  }

  /* --- FILTROS / BUSCADOR --- */
  .filters-bar {
    background: #ffffff;
    border-bottom: 1px solid #e2e8f0;
    padding: 1.5rem 0;
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .filters-flex {
    display: flex;
    align-items: center;
