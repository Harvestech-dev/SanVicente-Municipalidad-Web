/\/api-sanvicente.vecino.digital\/storage\/images\/eVsGIrUniBImEzt0zeZGffnQ9uME3UrJV3cPwzW6.jpg","path":"images\/eVsGIrUniBImEzt0zeZGffnQ9uME3UrJV3cPwzW6.jpg","type":"image","order":1,"mediable_type":"App\\Models\\News","mediable_id":10,"created_at":"2026-03-17T15:27:23.000000Z","updated_at":"2026-03-17T15:27:23.000000Z"},{"id":39,"name":"651046943_18361678711200974_4248882266634247087_n.jpg","url":"https:\/\/api-sanvicente.vecino.digital\/storage\/images\/Tn8ZfUNpsUfQesoOjEgz4w0NuyGuVNxHvWd8vLTL.jpg","path":"images\/Tn8ZfUNpsUfQesoOjEgz4w0NuyGuVNxHvWd8vLTL.jpg","type":"image","order":1,"mediable_type":"App\\Models\\News","mediable_id":10,"created_at":"2026-03-17T15:27:41.000000Z","updated_at":"2026-03-17T15:27:41.000000Z"},{"id":40,"name":"651046325_18361678663200974_5300894838273773612_n.jpg","url":"https:\/\/api-sanvicente.vecino.digital\/storage\/images\/ofaORQuZJP7SetO65Y0aOderzKKGOXq9DDP0YIIv.jpg","path":"images\/ofaORQuZJP7SetO65Y0aOderzKKGOXq9DDP0YIIv.jpg","type":"image","order":1,"mediable_type":"App\\Models\\News","mediable_id":10,"created_at":"2026-03-17T15:27:49.000000Z","updated_at":"2026-03-17T15:27:49.000000Z"},{"id":41,"name":"651051838_18361678612200974_607172107060953650_n.jpg","url":"https:\/\/api-sanvicente.vecino.digital\/storage\/images\/KBAOn6f5aQa87WRXY0AMsiQoh1ddKpo7IfrG9Z8L.jpg","path":"images\/KBAOn6f5aQa87WRXY0AMsiQoh1ddKpo7IfrG9Z8L.jpg","type":"image","order":1,"mediable_type":"App\\Models\\News","mediable_id":10,"created_at":"2026-03-17T15:27:56.000000Z","updated_at":"2026-03-17T15:27:56.000000Z"}],"links":[],"sounds":[],"videos":[],"event":null},{"id":14,"name":"OPERATIVO DE SATURACI\u00d3N: ACCIONES DE PREVENCI\u00d3N","extract":"A trav\u00e9s del \u00e1rea de Control P\u00fablico, se realiz\u00f3 un Operativo de Saturaci\u00f3n en conjunto con personal de la Comisar\u00eda 5ta, con el objetivo de prevenir contravenciones y reforzar el ordenamiento en la v\u00eda p\u00fablica.","body":"A trav\u00e9s del \u00e1rea de Control P\u00fablico, se realiz\u00f3 un Operativo de Saturaci\u00f3n en conjunto con personal de la Comisar\u00eda 5ta, con el objetivo de prevenir contravenciones y reforzar el ordenamiento en la v\u00eda p\u00fablica.\r\n\r\nComo resultado del procedimiento, se efectu\u00f3 la retenci\u00f3n de un motoveh\u00edculo por las siguientes infracciones: Escape antirreglamentario, falta de documentaci\u00f3n obligatoria y no poseer licencia de conducir.\r\n\r\nEstas acciones se desarrollan de manera preventiva para promover una circulaci\u00f3n m\u00e1s segura y el cumplimiento de las normas vigentes.","more_info":null,"landmark_id":null,"event_id":null,"published_from":"2026-03-12T03:00:00.000000Z","published_to":"2027-03-12T03:00:00.000000Z","is_important":true,"created_at":"2026-03-17T15:57:47.000000Z","updated_at":"2026-03-17T15:58:43.000000Z","deleted_at":null,"categories":[{"id":14,"name":"Control P\u00fablico","category_id":null,"external_id":null,"created_at":"2026-03-17T15:14:01.000000Z","updated_at":"2026-03-17T15:14:01.000000Z","pivot":{"categorizable_id":14,"category_id":14,"categorizable_type":"App\\Models\\News"}}],"landmark":null,"images":[{"id":66,"name":"651447536_18361444645200974_3625276349417049525_n.jpg","url":"https:\/\/api-sanvicente.vecino.digital\/storage\/images\/M2p9l1c56TX72D8OuyahbEBmGOzvXF8DdneHGrox.jpg","path":"images\/M2p9l1c56TX72D8OuyahbEBmGOzvXF8DdneHGrox.jpg","type":"image","order":1,"mediable_type":"App\\Models\\News","mediable_id":14,"created_at":"2026-03-17T15:57:47.000000Z","updated_at":"2026-03-17T15:57:47.000000Z"}],"links":[],"sounds":[],"videos":[],"event":null},{"id":8,"name":"SAN VICENTE PRESENTE EN LA INAUGURACI\u00d3N DEL STAND DEL GOBIERNO PROVINCIAL EN EXPOAGRO 2026","extract":"Este martes, el intendente Gonzalo Aira, junto al secretario de Intendencia, Gonzalo Bertossi, participaron de la inauguraci\u00f3n del stand del Gobierno de la Provincia de Santa Fe en Expoagro 2026, la principal exposici\u00f3n agroindustrial del pa\u00eds, que se desarrolla del 10 al 13 de marzo en el aut\u00f3dromo de San Nicol\u00e1s, provincia de Buenos Aires.","body":"Este martes, el intendente Gonzalo Aira, junto al secretario de Intendencia, Gonzalo Bertossi, participaron de la inauguraci\u00f3n del stand del Gobierno de la Provincia de Santa Fe en Expoagro 2026, la principal exposici\u00f3n agroindustrial del pa\u00eds, que se desarrolla del 10 al 13 de marzo en el aut\u00f3dromo de San Nicol\u00e1s, provincia de Buenos Aires.\r\n\r\nLa apertura cont\u00f3 con la participaci\u00f3n del gobernador Maximiliano Pullaro, el ministro de desarrollo productivo Gustavo Puccini y dem\u00e1s autoridades, en una muestra que re\u00fane a referentes del sector productivo, empresas, instituciones y gobiernos de todo el pa\u00eds.\r\nDurante la jornada, las autoridades locales tambi\u00e9n visitaron los espacios de empresas sanvicentinas que participan de la exposici\u00f3n, entre ellas OVER y Bernardin, firmas que contin\u00faan apostando al desarrollo productivo y representan a la industria local en uno de los eventos m\u00e1s importantes del sector agroindustrial.\r\n\r\nSANTA FE, PROTAGONISTA EN EXPOAGRO\r\nEl Gobierno de Santa Fe participa de Expoagro 2026 con una agenda enfocada en la promoci\u00f3n del entramado agroindustrial provincial. A trav\u00e9s del Ministerio de Desarrollo Productivo, el stand institucional funciona como un espacio para la promoci\u00f3n de inversiones, la generaci\u00f3n de negocios y la articulaci\u00f3n entre el sector p\u00fablico y privado.\r\nEn total, 170 empresas santafesinas forman parte de la megamuestra con stands, presentaciones, programas de financiamiento y rondas comerciales, mostrando el potencial productivo, tecnol\u00f3gico e innovador de la provincia y su aporte a la cadena de valor agroindustrial.","more_info":null,"landmark_id":null,"event_id":null,"published_from":"2026-03-11T03:00:00.000000Z","published_to":"2027-03-11T03:00:00.000000Z","is_important":false,"created_at":"2026-03-11T12:45:43.000000Z","updated_at":"2026-03-11T12:45:43.000000Z","deleted_at":null,"categories":[{"id":6,"name":"Producci\u00f3n","category_id":null,"external_id":null,"created_at":"2026-02-25T10:16:44.000000Z","updated_at":"2026-02-25T10:16:44.000000Z","pivot":{"categorizable_id":8,"category_id":6,"categorizable_type":"App\\Models\\News"}}],"landmark":null,"images":[{"id":19,"name":"WhatsApp Image 2026-03-11 at 9.40.01 AM.jpeg","url":"https:\/\/api-sanvicente.vecino.digital\/storage\/images\/GHW2QriMi7MtKoyO6s5YCNOZQvAKd6an3QjILOrG.jpeg","path":"images\/GHW2QriMi7MtKoyO6s5YCNOZQvAKd6an3QjILOrG.jpeg","type":"image","order":1,"mediable_type":"App\\Models\\News","mediable_id":8,"created_at":"2026-03-11T12:45:43.000000Z","updated_at":"2026-03-11T12:45:43.000000Z"},{"id":21,"name":"2026-03-10NID_285391O_5.jpeg","url":"https:\/\/api-sanvicente.vecino.digital\/storage\/images\/LMD42rZBmmqcxDNfAjkXwBQAMz2Yd96b2jb5TjBc.jpeg","path":"images\/LMD42rZBmmqcxDNfAjkXwBQAMz2Yd96b2jb5TjBc.jpeg","type":"image","order":1,"mediable_type":"App\\Models\\News","mediable_id":8,"created_at":"2026-03-11T12:51:55.000000Z","updated_at":"2026-03-11T12:51:55.000000Z"},{"id":22,"name":"WhatsApp Image 2026-03-11 at 9.40.02 AM.jpeg","url":"https:\/\/api-sanvicente.vecino.digital\/storage\/images\/bmroYYCMEe62iM448fkMPUQfwnkXJJkd3nMP2beL.jpeg","path":"images\/bmroYYCMEe62iM448fkMPUQfwnkXJJkd3nMP2beL.jpeg","type":"image","order":1,"mediable_type":"App\\Models\\News","mediable_id":8,"created_at":"2026-03-11T12:52:06.000000Z","updated_at":"2026-03-11T12:52:06.000000Z"},{"id":23,"name":"WhatsApp Image 2026-03-11 at 9.40.01 AM (2).jpeg","url":"https:\/\/api-sanvicente.vecino.digital\/storage\/images\/kRq5uJyoqn93HCRnSM1BVK20RXBxjkvi7d9JAK6q.jpeg","path":"images\/kRq5uJyoqn93HCRnSM1BVK20RXBxjkvi7d9JAK6q.jpeg","type":"image","order":1,"mediable_type":"App\\Models\\News","mediable_id":8,"created_at":"2026-03-11T12:52:16.000000Z","updated_at":"2026-03-11T12:52:16.000000Z"},{"id":24,"name":"WhatsApp Image 