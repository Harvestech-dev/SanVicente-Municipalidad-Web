---
import dataFallback from "../data/programas.json";
import sitioData from "../data/sitio.json";
import { getProgramSlug } from "../lib/programas-utils";

interface Programa {
  _orden?: number;
  boolean_featured?: boolean;
  txt_titulo?: string;
  txt_nombre?: string;
  txt_subtitulo?: string;
  txt_descripcion?: string;
  lista_descripcion?: Array<{ txt_descripcion?: string }>;
  lista_adjuntos?: Array<{ link_url?: string }>;
  attachments_adjuntos?: Array<{ txt_url?: string }>;
  link_url?: string;
  _sigla?: string;
  img_logo?: string;
  img_fondo?: string;
  gallery_imagenes?: Array<{ img_fondo?: string }>;
}

const { data: cmsData } = Astro.props;
const source = (cmsData as Record<string, unknown>) ?? dataFallback;

const programasRaw = (source.lista_programas ?? dataFallback.lista_programas ?? []) as Programa[];
const programasSorted = [...programasRaw].sort((a, b) => {
  const aF = a.boolean_featured ? 1 : 0;
  const bF = b.boolean_featured ? 1 : 0;
  return bF - aF;
});
const programas = programasSorted.slice(0, 6);

const titulo = (source.txt_titulo ?? dataFallback.txt_titulo ?? "Programas") as string;
const subtitulo = (source.txt_subtitulo ?? dataFallback.txt_subtitulo ?? "") as string;

const btn = source.btn_boton as { txt_label?: string; link_url?: string; _icon?: string } | undefined;
const textoVerTodo = (btn?.txt_label ?? "Ver todos los programas") as string;
const urlVerTodoRaw = (btn?.link_url ?? "/programas") as string;
const urlVerTodo = urlVerTodoRaw.startsWith("/") ? urlVerTodoRaw : `/${urlVerTodoRaw}`;

const ocultarSiNoHay = source.boolean_ocultar_si_no_hay_noticias ?? source.boolean_ocultar_si_no_hay_programas ?? false;
const listaDisclaimer = (source.lista_disclamer_sin_programas ?? source.lista_disclamer_sin_noticias ?? []) as Array<{ txt_parrafo?: string }>;

const hayProgramas = programas.length > 0;
const mostrarSeccion = hayProgramas || !ocultarSiNoHay;
const tema = sitioData._estilo;

function getProgramaNombre(p: Programa): string {
  return p.txt_titulo ?? p.txt_nombre ?? "";
}
function getProgramaDesc(p: Programa): string {
  if (p.txt_subtitulo) return p.txt_subtitulo;
  if (p.txt_descripcion) return p.txt_descripcion;
  const first = p.lista_descripcion?.[0]?.txt_descripcion;
  return first ?? "";
}
/** En la home se usa solo img_logo para las cards. */
function getProgramaImagen(p: Programa): string {
  return p.img_logo ?? "";
}
---

{
  mostrarSeccion && (
    <section class="featured-programs">
      <div class="container">
        <div class="header">
          {titulo && <h2 class="title">{titulo}</h2>}
          {subtitulo && <p class="subtitle">{subtitulo}</p>}
        </div>

        {hayProgramas ? (
          <>
            <div class="programs-grid">
              {
                programas.map((prog: Programa, i: number) => (
                  <a href={`/programas/${getProgramSlug(prog, i)}`} class="program-card">
                    <div class="logo-box">
                      {getProgramaImagen(prog) ? (
                        <img src={getProgramaImagen(prog)} alt={getProgramaNombre(prog)} />
                      ) : (
                        <span class="sigla">{prog._sigla ?? getProgramaNombre(prog).slice(0, 2).toUpperCase()}</span>
                      )}
                    </div>
                    <div class="content">
                      <h3 class="program-name">{getProgramaNombre(prog)}</h3>
                      <p class="program-desc">{getProgramaDesc(prog)}</p>
                    </div>
                  </a>
                ))
              }
            </div>
            {urlVerTodo && textoVerTodo && (
              <div class="action-container">
                <a href={urlVerTodo} class="btn-ver-todos">
                  {textoVerTodo}
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </a>
              </div>
            )}
          </>
        ) : (
          listaDisclaimer.length > 0 && (
            <div class="disclaimer-content">
              {listaDisclaimer.map((d) => d.txt_parrafo && <p>{d.txt_parrafo}</p>)}
            </div>
          )
        )}
      </div>
    </section>
  )
}

<style
  define:vars={{
    primario: tema.primario,
    texto: tema.texto,
    fondoClaro: "#f1f5f9",
  }}
>
  .featured-programs {
    padding: 5rem 1.5rem;
    background-color: var(--fondoClaro);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .title {
    font-size: clamp(1.75rem, 5vw, 2.25rem);
    font-weight: 800;
    color: var(--primario);
    margin-bottom: 0.75rem;
  }

  .subtitle {
    font-size: 1.1rem;
    color: #64748b;
    max-width: 600px;
    margin: 0 auto;
  }

  .programs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  .program-card {
    background: white;
    border-radius: 16px;
    padding: 1.25rem;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    border: 1px solid rgba(0, 0, 0, 0.05);
    transition: all 0.3s ease;
  }

  .program-card:hover {
    border-color: var(--primario);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);
  }

  .logo-box {
    width: 60px;
    height: 60px;
    border-radius: 12px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #374151;
    color: #ffffff;
    transition: transform 0.3s ease;
  }

  .program-card:hover .logo-box {
    transform: scale(1.05);
  }

  .sigla {
    font-size: 1.2rem;
    font-weight: 800;
  }

  .logo-box img {
    width: 60%;
    height: 60%;
    object-fit: contain;
    filter: brightness(0) invert(1);
  }

  .content {
    display: flex;
    flex-direction: column;
  }

  .program-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--texto);
    margin: 0;
  }

  .program-desc {
    font-size: 0.85rem;
    color: #64748b;
    margin-top: 0.25rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .action-container {
    margin-top: 3.5rem;
    display: flex;
    justify-content: center;
  }

  .btn-ver-todos {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: white;
    color: var(--primario);
    padding: 0.85rem 2rem;
    border: 1px solid var(--primario);
    border-radius: 14px;
    text-decoration: none;
    font-weight: 700;
    transition: all 0.3s ease;
  }

  .btn-ver-todos:hover {
    background: var(--primario);
    border-color: var(--primario);
    color: white;
  }

  .disclaimer-content {
    text-align: center;
    color: #64748b;
    max-width: 560px;
    margin: 0 auto;
  }

  .disclaimer-content p {
    margin-bottom: 0.75rem;
  }

  .disclaimer-content p:last-child {
    margin-bottom: 0;
  }
</style>
